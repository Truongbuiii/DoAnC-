@model AdminWeb.Models.Tour

@{
    ViewData["Title"] = "Chỉnh sửa Lộ trình";
    var allPois = ViewBag.AllPois as IEnumerable<AdminWeb.Models.POI>;
    var selectedIds = ViewBag.SelectedPoiIds as List<int> ?? new List<int>();
}

<div class="container py-4">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="TourId" />
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-0">Cập nhật Lộ trình</h2>
                <p class="text-muted small">Mã hành trình: #@Model.TourId</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-light border rounded-pill px-4">Hủy</a>
                <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-save me-2"></i>Lưu thay đổi
                </button>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <div class="mb-4">
                        <label asp-for="TourName" class="form-label fw-bold">Tên Hành Trình</label>
                        <input asp-for="TourName" class="form-control rounded-3" />
                        <span asp-validation-for="TourName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Ảnh đại diện</label>
                        @if (!string.IsNullOrEmpty(Model.ImageSource))
                        {
                            <div class="mb-2">
                                <img src="~/images/@Model.ImageSource" class="rounded-3 shadow-sm border" style="height: 120px; width: 200px; object-fit: cover;" />
                                <p class="small text-muted mt-1"><i class="bi bi-image me-1"></i>Ảnh hiện tại trên hệ thống</p>
                            </div>
                        }
                        <input type="file" name="imgFile" class="form-control rounded-3" accept="image/*" />
                        <small class="text-muted">Để trống nếu bạn không muốn thay đổi ảnh.</small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="TotalTime" class="form-label fw-bold">Thời gian dự kiến</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-clock"></i></span>
                            <input asp-for="TotalTime" class="form-control rounded-end-3 border-start-0" />
                        </div>
                    </div>

                    <div class="mb-0">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả hành trình</label>
                        <textarea asp-for="Description" class="form-control rounded-3" rows="5"></textarea>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                    <div class="card-header bg-dark py-3">
                        <h6 class="text-white mb-0 fw-bold"><i class="bi bi-list-check me-2"></i>Chọn các điểm đến</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 600px; overflow-y: auto;">
                            @if (allPois != null)
                            {
                                foreach (var poi in allPois)
                                {
                                    bool isChecked = selectedIds.Contains(poi.PoiId);
                                    <label class="list-group-item d-flex align-items-center py-3 pointer">
                                        <input class="form-check-input me-3 flex-shrink-0" type="checkbox" name="selectedPois" value="@poi.PoiId" @(isChecked ? "checked" : "")>
                                        <div class="flex-grow-1">
                                            <span class="fw-bold d-block text-dark">@poi.Name</span>
                                            @* Đã sửa thành Category để không lỗi *@
                                            <span class="text-muted x-small"><i class="bi bi-tag me-1"></i>@(poi.Category ?? "Chưa phân loại")</span>
                                        </div>
                                    </label>
                                }
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-light border-0 py-3 text-center">
                        <small class="text-muted">Tích chọn để cập nhật danh sách địa điểm trong tour.</small>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .pointer { cursor: pointer; }
    .list-group::-webkit-scrollbar { width: 6px; }
    .list-group::-webkit-scrollbar-thumb { background: #ced4da; border-radius: 10px; }
    .x-small { font-size: 0.75rem; }
    .object-fit-cover { object-fit: cover; }
</style>