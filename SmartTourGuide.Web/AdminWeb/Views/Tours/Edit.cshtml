@model AdminWeb.Models.Tour

@{
    ViewData["Title"] = "Chỉnh sửa Hành trình";
    var allPois = ViewBag.AllPois as List<AdminWeb.Models.POI>;
    var selectedIds = ViewBag.SelectedPoiIds as List<int> ?? new List<int>();
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Cập nhật Hành trình: @Model.TourName</h5>
                    <span class="badge bg-dark">Tour ID: #@Model.TourId</span>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="TourId" />

                        <div class="row">
                            <div class="col-md-4 border-end">
                                <h6 class="fw-bold text-muted mb-3 small uppercase">1. Thông tin cơ bản</h6>
                                <div class="mb-3">
                                    <label asp-for="TourName" class="form-label small fw-bold"></label>
                                    <input asp-for="TourName" class="form-control rounded-3" />
                                    <span asp-validation-for="TourName" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="TotalTime" class="form-label small fw-bold"></label>
                                    <input asp-for="TotalTime" class="form-control rounded-3" />
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label small fw-bold"></label>
                                    <textarea asp-for="Description" class="form-control rounded-3" rows="5"></textarea>
                                </div>
                            </div>

                            <div class="col-md-8 ps-md-4">
                                <h6 class="fw-bold text-muted mb-3 small uppercase">2. Thiết lập lại lộ trình (Chọn & Sắp xếp)</h6>
                                <div class="alert alert-info py-2 small border-0 shadow-xs">
                                    <i class="bi bi-info-circle me-2"></i>Tài chọn lại các quán ốc. Thứ tự sẽ được lưu theo trình tự Tài tích chọn.
                                </div>

                                <div class="row g-3">
                                    @foreach (var poi in allPois)
                                    {
                                        bool isChecked = selectedIds.Contains(poi.PoiId);
                                        <div class="col-md-6">
                                            <div class="poi-selection-card @(isChecked ? "active" : "")">
                                                <div class="form-check d-flex align-items-center p-0 m-0 w-100 h-100">
                                                    <input type="checkbox" name="selectedPois" value="@poi.PoiId" 
                                                           class="form-check-input ms-3 me-3" @(isChecked ? "checked" : "")>
                                                    <label class="form-check-label py-3 pe-3 w-100 cursor-pointer">
                                                        <div class="fw-bold text-dark">@poi.Name</div>
                                                        <div class="text-muted" style="font-size: 0.75rem;">@poi.Category</div>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-3 border-top d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy thay đổi</a>
                            <button type="submit" class="btn btn-warning rounded-pill px-5 fw-bold shadow-sm">
                                <i class="bi bi-save me-2"></i>Cập nhật hành trình
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .poi-selection-card {
        border: 1px solid #dee2e6;
        border-radius: 12px;
        transition: all 0.2s ease;
        background: #fff;
    }
    .poi-selection-card:hover { border-color: #ffc107; background: #fffcf0; }
    .poi-selection-card.active { border-color: #ffc107; background: #fff9e6; border-width: 2px; }
    .cursor-pointer { cursor: pointer; }
    .uppercase { text-transform: uppercase; letter-spacing: 1px; }
</style>