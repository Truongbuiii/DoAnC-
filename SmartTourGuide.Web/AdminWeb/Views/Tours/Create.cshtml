@model AdminWeb.Models.Tour

@{
    ViewData["Title"] = "Thiết kế Tour mới";
}

<div class="container py-4">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-0">Thiết kế Tour mới</h2>
                <p class="text-muted small">Điền thông tin và chọn các điểm đến cho lộ trình</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-light border rounded-pill px-4">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-check2-circle me-2"></i>Lưu cấu hình
                </button>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold mb-4 text-primary">Thông tin cơ bản</h5>
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="TourName" class="form-label fw-bold">Tên Hành Trình</label>
                        <input asp-for="TourName" class="form-control form-control-lg rounded-3" placeholder="VD: Khám phá Vĩnh Khánh đêm" />
                        <span asp-validation-for="TourName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Ảnh đại diện Tour</label>
                        <input type="file" name="imgFile" class="form-control rounded-3" accept="image/*" />
                        <small class="text-muted">Chọn ảnh tiêu biểu cho Phố ẩm thực</small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="TotalTime" class="form-label fw-bold">Tổng thời gian dự kiến</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-clock"></i></span>
                            <input asp-for="TotalTime" class="form-control rounded-end-3 border-start-0" placeholder="VD: 2 giờ 30 phút" />
                        </div>
                    </div>

                    <div class="mb-0">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả tóm tắt</label>
                        <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Mô tả ngắn gọn..."></textarea>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header bg-dark p-3">
                        <h6 class="text-white mb-0 fw-bold"><i class="bi bi-geo-fill me-2 text-warning"></i>Thiết lập điểm dừng</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                            @if (ViewBag.Pois != null)
                            {
                                foreach (var poi in (IEnumerable<AdminWeb.Models.POI>)ViewBag.Pois)
                                {
                                    <div class="list-group-item d-flex align-items-center py-3 border-light">
                                        <div class="form-check me-2">
                                            <input class="form-check-input pointer" type="checkbox" name="selectedPois" value="@poi.PoiId" id="poi_@poi.PoiId">
                                        </div>
                                        <div class="flex-grow-1">
                                            <label class="fw-bold text-dark d-block mb-0 pointer" for="poi_@poi.PoiId">@poi.Name</label>
                                            @* Đã sửa Address thành Category để không bị lỗi *@
                                            <span class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-tag me-1"></i>@poi.Category</span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-light border-0 py-3 text-center">
                        <small class="text-muted">Tích chọn theo thứ tự bạn muốn dừng chân</small>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .pointer { cursor: pointer; }
    .list-group::-webkit-scrollbar { width: 5px; }
    .list-group::-webkit-scrollbar-thumb { background: #dee2e6; border-radius: 10px; }
</style>