@model AdminWeb.Models.Tour

@{
    ViewData["Title"] = "Thiết kế Hành trình";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-geo-alt-fill me-2"></i>Thiết kế Hành trình Tour Mới</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-5 border-end">
                                <h6 class="text-uppercase fw-bold text-muted mb-3 small">Thông tin chung</h6>
                                <div class="mb-3">
                                    <label asp-for="TourName" class="form-label fw-medium"></label>
                                    <input asp-for="TourName" class="form-control rounded-pill" placeholder="VD: Tour Ốc Michelin..." />
                                    <span asp-validation-for="TourName" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="TotalTime" class="form-label fw-medium"></label>
                                    <input asp-for="TotalTime" class="form-control rounded-pill" placeholder="VD: 2 giờ 30 phút" />
                                    <span asp-validation-for="TotalTime" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-medium"></label>
                                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả ngắn gọn về hành trình này..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-7 ps-md-4">
                                <h6 class="text-uppercase fw-bold text-muted mb-3 small">Thiết lập lộ trình (Chọn quán ốc)</h6>
                                <p class="text-muted small italic mb-3"><i class="bi bi-info-circle me-1"></i>Tích chọn các quán ốc Tài muốn đưa vào tour này.</p>
                                
                                <div class="list-group shadow-sm overflow-auto" style="max-height: 350px;">
                                    @if (ViewBag.PoiList != null)
                                    {
                                        var pois = (List<AdminWeb.Models.POI>)ViewBag.PoiList;
                                        foreach (var poi in pois)
                                        {
                                            <label class="list-group-item d-flex gap-3 align-items-center border-start-0 border-end-0 py-3 pointer">
                                                <input class="form-check-input flex-shrink-0" type="checkbox" name="selectedPois" value="@poi.PoiId" style="width: 1.2rem; height: 1.2rem;">
                                                <div class="d-flex flex-column">
                                                    <span class="fw-bold">@poi.Name</span>
                                                    <span class="text-muted x-small">@poi.Category</span>
                                                </div>
                                            </label>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4"><i class="bi bi-arrow-left me-1"></i> Quay lại</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 shadow">
                                <i class="bi bi-check-circle me-1"></i> Hoàn tất & Lưu Tour
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .pointer { cursor: pointer; }
    .x-small { font-size: 0.75rem; }
    .list-group-item:hover { background-color: #f8f9fa; }
    .form-check-input:checked { background-color: #0d6efd; border-color: #0d6efd; }
</style>