@{ 
    Layout = null; 
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập Hệ thống - Smart Tour</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { 
            background: linear-gradient(135deg, #f0f2f5 0%, #e2e8f0 100%); 
            font-family: 'Inter', sans-serif; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            height: 100vh; 
            margin: 0; 
        }
        .login-box { 
            background: white; 
            padding: 40px; 
            border-radius: 24px; 
            box-shadow: 0 20px 40px rgba(0,0,0,0.1); 
            width: 100%; 
            max-width: 400px; 
            border: 1px solid rgba(255,255,255,0.8); 
        }
        .btn-primary { 
            background: #4e73df; 
            border: none; 
            padding: 14px; 
            border-radius: 12px; 
            font-weight: 700; 
            width: 100%; 
            transition: 0.3s; 
            letter-spacing: 0.5px;
        }
        .btn-primary:hover { 
            background: #224abe; 
            transform: translateY(-2px); 
            box-shadow: 0 8px 15px rgba(78, 115, 223, 0.3);
        }
        /* Style cho ô nhập liệu có Icon */
        .input-group-text {
            background-color: #f8faff;
            border-right: none;
            color: #94a3b8;
            border-radius: 12px 0 0 12px;
        }
        .form-control { 
            border-radius: 12px; 
            padding: 12px 15px; 
            border: 1px solid #dee2e6;
        }
        .form-control:focus {
            border-color: #4e73df;
            box-shadow: 0 0 0 4px rgba(78, 115, 223, 0.1);
        }
        .input-group .form-control {
            border-left: none;
            border-radius: 0 12px 12px 0;
        }
        .icon-circle {
            width: 70px;
            height: 70px;
            background: #f8faff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: #4e73df;
            font-size: 2.5rem;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="text-center mb-4">
            <div class="icon-circle shadow-sm">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h3 class="fw-bold text-dark mb-1">Smart Tour Admin</h3>
            <p class="text-muted small">Nhập thông tin quản trị để truy cập</p>
        </div>

        @if (ViewBag.Error != null) {
            <div class="alert alert-danger py-2 text-center small border-0 mb-3" style="border-radius: 10px;">
                <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
            </div>
        }

        @* FORM ĐÃ TÍCH HỢP RETURNURL *@
        <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
            
            @* Input ẩn để lưu đường dẫn quay lại sau khi login *@
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">Tài khoản</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-person-fill"></i>
                    </span>
                    <input type="text" name="username" class="form-control" placeholder="Tên đăng nhập" required autocomplete="off">
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-key-fill"></i>
                    </span>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit" class="btn btn-primary shadow-sm text-uppercase">
                Đăng nhập ngay
            </button>
        </form>
        
        <div class="text-center mt-4">
            <p class="text-muted small mb-0">&copy; 2026 Smart Tour Guide System</p>
        </div>
    </div>
</body>
</html>