@{ 
    Layout = null; 
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Smart Tour</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #f8fafc;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            color: #0f172a;
        }
        .login-wrapper {
            width: 100%;
            max-width: 400px;
            padding: 20px;
        }
        .brand-icon {
            width: 48px;
            height: 48px;
            background: #0f172a;
            color: white;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 16px;
            box-shadow: 0 4px 10px rgba(15, 23, 42, 0.2);
        }
        .login-card {
            background: white;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
        }
        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #475569;
            margin-bottom: 8px;
        }
        .form-control {
            border-radius: 8px;
            padding: 12px 14px;
            border: 1px solid #cbd5e1;
            font-size: 0.95rem;
            color: #0f172a;
            transition: all 0.2s ease;
            box-shadow: none !important;
        }
        .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15) !important;
        }
        
        /* Tinh chỉnh riêng cho ô Password có nút Mắt */
        .input-pwd .form-control {
            border-right: none;
            border-top-right-radius: 0;
            border-bottom-right-radius: 0;
        }
        /* Viền sáng lên cùng lúc cả ô chữ và ô mắt khi click */
        .input-pwd:focus-within .form-control,
        .input-pwd:focus-within .input-group-text {
            border-color: #3b82f6;
        }
        .input-pwd .input-group-text {
            background: transparent;
            border: 1px solid #cbd5e1;
            border-left: none;
            border-radius: 0 8px 8px 0;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .btn-login {
            background-color: #0f172a;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-weight: 600;
            width: 100%;
            font-size: 0.95rem;
            transition: 0.2s;
            margin-top: 15px;
        }
        .btn-login:hover {
            background-color: #1e293b;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        }
        .footer-text {
            text-align: center;
            font-size: 0.8rem;
            color: #94a3b8;
            margin-top: 25px;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="text-center mb-4">
            <div class="brand-icon">
                <i class="bi bi-hdd-network-fill"></i>
            </div>
            <h3 class="fw-bold mb-1" style="letter-spacing: -0.5px;">Smart Tour</h3>
            <p class="text-muted small">Đăng nhập để truy cập trang quản trị</p>
        </div>

        <div class="login-card">
            @if (ViewBag.Error != null) {
                <div class="alert alert-danger p-2 text-center small border-0 mb-4 rounded-2" style="background-color: #fef2f2; color: #dc2626;">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Error
                </div>
            }

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div class="mb-4">
                    <label class="form-label">Tài khoản</label>
                    <input type="text" name="username" class="form-control" placeholder="Tên đăng nhập" required autocomplete="off">
                </div>

                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <div class="input-group input-pwd">
                        <input type="password" name="password" id="pwdInput" class="form-control" placeholder="••••••••" required>
                        <span class="input-group-text" id="togglePwd">
                            <i class="bi bi-eye-slash" id="eyeIcon"></i>
                        </span>
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    Đăng nhập
                </button>
            </form>
        </div>
        
        <div class="footer-text">
            &copy; 2026 Smart Tour Guide System
        </div>
    </div>

    <script>
        document.getElementById('togglePwd').addEventListener('click', function () {
            var pwdInput = document.getElementById('pwdInput');
            var eyeIcon = document.getElementById('eyeIcon');
            
            if (pwdInput.type === 'password') {
                pwdInput.type = 'text';
                eyeIcon.classList.remove('bi-eye-slash');
                eyeIcon.classList.add('bi-eye');
                eyeIcon.style.color = '#3b82f6'; // Mắt sáng lên màu xanh
            } else {
                pwdInput.type = 'password';
                eyeIcon.classList.remove('bi-eye');
                eyeIcon.classList.add('bi-eye-slash');
                eyeIcon.style.color = ''; // Mắt tắt đi
            }
        });
    </script>
</body>
</html>