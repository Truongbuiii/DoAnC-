@model AdminWeb.Models.ChangePasswordViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Thiết lập mật khẩu</h4>
                    <form asp-action="ChangePassword" method="post">
                        <div class="mb-3">
                            <label class="small fw-bold mb-1">Mật khẩu hiện tại</label>
                            <input asp-for="CurrentPassword" class="form-control rounded-3" type="password" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="small fw-bold mb-1">Mật khẩu mới</label>
                            <input asp-for="NewPassword" class="form-control rounded-3" type="password" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label class="small fw-bold mb-1">Xác nhận mật khẩu mới</label>
                            <input asp-for="ConfirmPassword" class="form-control rounded-3" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-2">Lưu thay đổi</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>