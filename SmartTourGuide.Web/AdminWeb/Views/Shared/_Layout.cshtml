@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smart Tour Admin - Phố Vĩnh Khánh</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
    
    <style>
        /* Thêm một chút style để sidebar nhìn xịn hơn */
        .sidebar a {
            text-decoration: none;
            display: block;
            padding: 12px 20px;
            color: #adb5bd;
            transition: 0.3s;
        }
        .sidebar a:hover, .sidebar a.active {
            background: #343a40;
            color: #fff;
            border-left: 4px solid #0d6efd;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="p-3">
            <h2 class="text-white fs-4">Smart Tour</h2>
            <hr class="text-secondary">
        </div>

        @{
            // Lấy tên Controller hiện tại để tự động active menu
            var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        }

        <a asp-controller="POI" asp-action="Index" 
           class="@(currentController == "POI" ? "active" : "")">
           <i class="bi bi-map-fill me-2"></i> Quản lý POI
        </a>

        <a asp-controller="Audios" asp-action="Index" 
           class="@(currentController == "Audios" ? "active" : "")">
           <i class="bi bi-mic-fill me-2"></i> Quản lý Audio
        </a>

        @* ĐÃ SỬA: asp-controller="Tours" (có s) để khớp với code Scaffold *@
        <a asp-controller="Tours" asp-action="Index" 
           class="@(currentController == "Tours" ? "active" : "")">
           <i class="bi bi-signpost-split-fill me-2"></i> Quản lý Tour
        </a>

        <a asp-controller="Analytics" asp-action="Index" 
           class="@(currentController == "Analytics" ? "active" : "")">
           <i class="bi bi-graph-up-arrow me-2"></i> Analytics
        </a>

        <div class="mt-5 p-3">
            <a asp-controller="Account" asp-action="Logout" class="text-danger">
                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="main">
        <div class="topbar d-flex justify-content-between align-items-center px-4">
            <span class="fw-bold">Smart Tour Guide Admin</span>
            <span class="badge bg-light text-dark">Chào Tài, @User.Identity?.Name</span>
        </div>

        <div class="content p-4">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/poi-management.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>