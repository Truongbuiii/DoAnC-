@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smart Tour Admin - Phố Vĩnh Khánh</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
    
    <style>
        /* Sidebar styling */
        .sidebar a {
            text-decoration: none;
            display: block;
            padding: 12px 20px;
            color: #adb5bd;
            transition: 0.3s;
        }
        .sidebar a:hover, .sidebar a.active {
            background: #343a40;
            color: #fff;
            border-left: 4px solid #0d6efd;
        }
        .main { margin-left: 250px; }
    </style>
</head>
<body>
    <div class="sidebar" style="width: 250px; height: 100vh; position: fixed; background: #212529;">
        <div class="p-3">
            <h2 class="text-white fs-4">Smart Tour</h2>
            <hr class="text-secondary">
        </div>

        @{
            var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        }

        @* 1. QUẢN LÝ POI - AI CŨNG THẤY *@
        <a asp-controller="POI" asp-action="Index" 
           class="@(currentController == "POI" ? "active" : "")">
           <i class="bi bi-map-fill me-2"></i> Quản lý POI
        </a>

        @* 2. QUẢN LÝ TÀI KHOẢN - CHỈ ADMIN THẤY *@
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admins" asp-action="Index" 
               class="@(currentController == "Admins" ? "active" : "")">
               <i class="bi bi-person-badge-fill me-2"></i> Quản lý Tài khoản
            </a>
        }

        @* 3. QUẢN LÝ AUDIO - AI CŨNG THẤY *@
        <a asp-controller="Audios" asp-action="Index" 
           class="@(currentController == "Audios" ? "active" : "")">
           <i class="bi bi-mic-fill me-2"></i> Quản lý Audio
        </a>

        @* 4. QUẢN LÝ TOUR - CHỈ ADMIN THẤY (BƯỚC 1 ĐÃ SỬA TẠI ĐÂY) *@
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Tours" asp-action="Index" 
               class="@(currentController == "Tours" ? "active" : "")">
               <i class="bi bi-signpost-split-fill me-2"></i> Quản lý Tour
            </a>
        }

        @* 5. THỐNG KÊ - AI CŨNG THẤY (LỌC DỮ LIỆU Ở CONTROLLER) *@
        <a asp-controller="Analytics" asp-action="Index" 
           class="@(currentController == "Analytics" ? "active" : "")">
           <i class="bi bi-graph-up-arrow me-2"></i> Analytics
        </a>

        <div class="mt-5 p-3">
            <a asp-controller="Account" asp-action="Logout" class="text-danger border-0 bg-transparent w-100 text-start">
                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="main">
        <div class="topbar d-flex justify-content-between align-items-center px-4 shadow-sm bg-white" style="height: 60px;">
            <span class="fw-bold text-dark">Smart Tour Guide Admin</span>
            <div>
                <span class="badge bg-primary me-2">@(User.IsInRole("Admin") ? "Admin" : "Chủ Quán")</span>
                <span class="text-dark fw-bold">Chào, @User.Identity?.Name</span>
            </div>
        </div>

        <div class="content p-4">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/poi-management.js" asp-append-version="true"></script>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>