@model IEnumerable<AdminWeb.Models.ActivityLog>

@{
    ViewData["Title"] = "Nhật ký hệ thống";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Lịch sử & Sử dụng</h2>
            <p class="text-muted small">Dữ liệu tương tác thực tế từ khách du lịch tại phố Vĩnh Khánh</p>
        </div>
        <div class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
            Tổng cộng: @Model.Count() lượt tương tác
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-muted small text-uppercase">
                        <th class="ps-4 py-3">Thời gian</th>
                        <th>Địa điểm (POI)</th>
                        <th>Hành động</th>
                        <th class="text-center">Ngôn ngữ</th>
                        <th>Thiết bị</th>
                        <th class="text-center">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@log.AccessTime?.ToString("dd/MM/yyyy")</div>
                                <div class="text-muted small">@log.AccessTime?.ToString("HH:mm:ss")</div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;">
                                        <i class="bi bi-geo-alt"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@(log.Poi?.Name ?? "N/A")</div>
                                        <div class="text-muted x-small">ID: #@log.PoiId</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-info-subtle text-info px-3">
                                    <i class="bi bi-play-circle me-1"></i> @log.ActionType
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-dark rounded-pill px-3">@log.LanguageUsed</span>
                            </td>
                            <td>
                                <div class="small"><i class="bi bi-phone me-1"></i> @log.DeviceType</div>
                            </td>
                            <td class="text-center">
                                <i class="bi bi-check-circle-fill text-success"></i>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.7rem; }
    .table thead th { font-weight: 600; font-size: 0.75rem; border-bottom: none; }
    .table tbody td { border-color: #f8f9fa; }
</style>