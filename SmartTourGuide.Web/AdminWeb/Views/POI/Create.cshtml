@model AdminWeb.Models.POI

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body { background-color: #f4f7f6; font-family: 'Inter', sans-serif; }
    .form-container { max-width: 1000px; margin: 30px auto; }
    .card-custom { border: none; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); background: white; }
    .card-header-custom { background-color: #4e73df; color: white; border-radius: 16px 16px 0 0 !important; padding: 20px; }
    
    .form-label { font-weight: 600; color: #4a5568; font-size: 0.9rem; margin-bottom: 8px; display: block; }
    .form-control, .form-select { 
        border-radius: 10px; 
        border: 1px solid #e2e8f0; 
        padding: 12px 15px; 
        transition: 0.3s;
    }
    .form-control:focus { border-color: #4e73df; box-shadow: 0 0 0 3px rgba(78, 115, 223, 0.1); }
    
    .lang-section { background: #f8fafc; border-radius: 12px; padding: 20px; border: 1px solid #edf2f7; }
    .lang-title { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: #718096; margin-bottom: 15px; }
    
    .btn-save { background: #4e73df; color: white; border-radius: 10px; padding: 12px 30px; font-weight: 700; border: none; transition: 0.3s; cursor: pointer; }
    .btn-save:hover { background: #2e59d9; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(78, 115, 223, 0.3); }
    .btn-cancel { border-radius: 10px; padding: 12px 30px; font-weight: 600; text-decoration: none; color: #718096; transition: 0.3s; }
    .btn-cancel:hover { color: #2d3748; background: #edf2f7; }
</style>

<div class="container form-container">
    <div class="card card-custom">
        <div class="card-header-custom">
            <h4 class="mb-0 fw-bold text-white"><i class="bi bi-plus-circle-fill me-2"></i>Thêm Điểm Thuyết Minh Mới</h4>
        </div>
        
        <div class="card-body p-4 p-md-5">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                
                <div class="row mb-4">
                    <div class="col-md-7">
                        <label class="form-label">Tên địa điểm (Chính)</label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="Ví dụ: Ốc Oanh 534..." required />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Phân loại quán</label>
                        <select asp-for="Category" class="form-select form-control-lg">
                            <option value="">-- Chọn danh mục --</option>
                            <option value="Quán ốc">Quán ốc</option>
                            <option value="Lẩu dê">Lẩu dê</option>
                            <option value="Hải sản">Hải sản</option>
                            <option value="Món Lẩu">Món Lẩu</option>
                            <option value="Ăn vặt">Ăn vặt</option>
                            <option value="Đồ Nhật">Đồ Nhật</option>
                            <option value="Điểm tham quan">Điểm tham quan</option>
                        </select>
                    </div>
                </div>

                <hr class="my-4" style="opacity: 0.1;">

                <div class="lang-section mb-4 shadow-sm">
                    <div class="lang-title"><i class="bi bi-translate me-2"></i>Nội dung thuyết minh (Multilingual)</div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-danger">Tiếng Việt (VN)</label>
                            <textarea asp-for="DescriptionVi" class="form-control" rows="3" placeholder="Chào mừng bạn đến với..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-primary">Tiếng Anh (EN)</label>
                            <textarea asp-for="DescriptionEn" class="form-control" rows="3" placeholder="Welcome to..."></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tiếng Trung (ZH)</label>
                            <textarea asp-for="DescriptionZh" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tiếng Hàn (KO)</label>
                            <textarea asp-for="DescriptionKo" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tiếng Nhật (JA)</label>
                            <textarea asp-for="DescriptionJa" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>

                <div class="row mb-5">
                    <div class="col-md-4">
                        <label class="form-label">Hình ảnh quán</label>
                        <div class="p-3 border rounded-3 bg-light text-center shadow-sm">
                            <input type="file" name="imageFile" class="form-control mb-2" accept="image/*" />
                            <small class="text-muted">Định dạng: JPG, PNG, WebP</small>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Vị trí GPS & Radar</label>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <input asp-for="Latitude" class="form-control" placeholder="Vĩ độ (Lat)" required />
                            </div>
                            <div class="col-md-4">
                                <input asp-for="Longitude" class="form-control" placeholder="Kinh độ (Long)" required />
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <input asp-for="TriggerRadius" class="form-control" placeholder="Bán kính" />
                                    <span class="input-group-text">m</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-between pt-4 border-top">
                    <a asp-action="Index" class="btn-cancel"><i class="bi bi-arrow-left me-2"></i>Quay lại danh sách</a>
                    <button type="submit" class="btn-save shadow"><i class="bi bi-check-lg me-2"></i>Lưu địa điểm</button>
                </div>
            </form>
        </div>
    </div>
</div>