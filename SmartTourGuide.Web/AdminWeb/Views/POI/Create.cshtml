@model AdminWeb.Models.POI

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<style>
    body { background-color: #f4f7f6; font-family: 'Inter', sans-serif; }
    .form-container { max-width: 1000px; margin: 30px auto; }
    .card-custom { border: none; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); background: white; }
    .card-header-custom { background-color: #4e73df; color: white; border-radius: 16px 16px 0 0 !important; padding: 20px; }
    .form-label { font-weight: 600; color: #4a5568; font-size: 0.9rem; margin-bottom: 8px; display: block; }
    .form-control, .form-select { border-radius: 10px; border: 1px solid #e2e8f0; padding: 12px 15px; transition: 0.3s; }
    .lang-section { background: #f8fafc; border-radius: 12px; padding: 20px; border: 1px solid #edf2f7; }
    .btn-save { background: #4e73df; color: white; border-radius: 10px; padding: 12px 30px; font-weight: 700; border: none; transition: 0.3s; cursor: pointer; }
    .btn-save:hover { background: #2e59d9; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(78, 115, 223, 0.3); }
</style>

<div class="container form-container">
    <div class="card card-custom">
        <div class="card-header-custom">
            <h4 class="mb-0 fw-bold text-white"><i class="bi bi-plus-circle-fill me-2"></i>Thêm Điểm Thuyết Minh Mới</h4>
        </div>

        <div class="card-body p-4 p-md-5">
            <div asp-validation-summary="All" class="text-danger mb-4 p-3 border rounded-3 bg-light shadow-sm" style="list-style-type: none;"></div>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row mb-4">
                    <div class="col-md-7">
                        <label class="form-label">Tên địa điểm (Chính)</label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="Ví dụ: Ốc Oanh 534..." required />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Phân loại quán</label>
                        <select asp-for="Category" class="form-select form-control-lg" required>
                            <option value="">-- Chọn danh mục --</option>
                            <option value="Quán ốc">Quán ốc</option>
                            <option value="Lẩu dê">Lẩu dê</option>
                            <option value="Hải sản">Hải sản</option>
                            <option value="Điểm tham quan">Điểm tham quan</option>
                        </select>
                    </div>
                </div>

                <div class="lang-section mb-4 shadow-sm">
                    <label class="form-label text-primary fw-bold">Nội dung thuyết minh (Tiếng Việt)</label>
                    <textarea asp-for="DescriptionVi" class="form-control" rows="5" placeholder="Nhập mô tả quán..."></textarea>
                </div>

                <div class="row mb-4">
                    <div class="col-md-12">
                        <label class="form-label">Hình ảnh quán</label>
                        <div class="p-3 border rounded-3 bg-light shadow-sm">
                            <input type="file" name="imageFile" class="form-control mb-2" accept="image/*" />
                            <small class="text-muted">Định dạng: JPG, PNG, WebP</small>
                        </div>
                    </div>
                </div>

                <div class="lang-section mb-4 shadow-sm">
                    <div id="map-picker" style="height:350px;border-radius:10px;margin-bottom:16px;border:1px solid #e2e8f0;"></div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Vĩ độ (Latitude)</label>
                            <input asp-for="Latitude" id="lat-input" class="form-control font-monospace" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Kinh độ (Longitude)</label>
                            <input asp-for="Longitude" id="lon-input" class="form-control font-monospace" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bán kính kích hoạt (m)</label>
                            <input asp-for="TriggerRadius" class="form-control" placeholder="35" />
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-between pt-4 border-top">
                    <a asp-action="Index" class="btn-cancel text-decoration-none text-muted"> <i class="bi bi-arrow-left me-2"></i>Quay lại </a>
                    <button type="submit" class="btn-save shadow"> <i class="bi bi-check-lg me-2"></i>Lưu địa điểm </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    var initLat = 10.761858; var initLon = 106.702236;
    var map = L.map('map-picker').setView([initLat, initLon], 17);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(map);
    var marker = L.marker([initLat, initLon], { draggable: true }).addTo(map);
    map.on('click', function(e) { marker.setLatLng(e.latlng); updateInputs(e.latlng.lat, e.latlng.lng); });
    marker.on('dragend', function(e) { var pos = marker.getLatLng(); updateInputs(pos.lat, pos.lng); });
    function updateInputs(lat, lng) { 
        document.getElementById('lat-input').value = lat.toFixed(6); 
        document.getElementById('lon-input').value = lng.toFixed(6); 
    }
</script>