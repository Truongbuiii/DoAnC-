@model AdminWeb.Models.POI

<h2>Add POI</h2>

<form method="post">

    <div>
        <label>Name</label>
        <input asp-for="Name" />
    </div>

    <div>
        <label>Latitude</label>
        <input asp-for="Latitude" />
    </div>

    <div>
        <label>Longitude</label>
        <input asp-for="Longitude" />
    </div>

    <div>
        <label>Trigger Radius</label>
        <input asp-for="TriggerRadius" />
    </div>

    <div>
        <label>Description</label>
        <input asp-for="Description" />
    </div>

    <div>
        <label>Category</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories"></select>
    </div>

    <br>

    <button type="submit">Save</button>

</form>

<a href="/POI">Back</a>