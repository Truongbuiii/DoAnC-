@model AdminWeb.Models.POI

<div class="container mt-4">
    <h2 class="text-primary"><i class="bi bi-plus-circle me-2"></i>Thêm điểm thuyết minh mới</h2>
    <hr />

    @* QUAN TRỌNG: Chỉ dùng 1 thẻ form và phải có enctype="multipart/form-data" *@
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row">
            <div class="col-md-8">
                <div class="form-group mb-3">
                    <label class="fw-bold">Tên địa điểm</label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên quán ăn..." />
                </div>

                <div class="form-group mb-3">
                    <label class="fw-bold">Nội dung thuyết minh (TTS)</label>
                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Nội dung máy sẽ đọc..."></textarea>
                </div>
            </div>

            <div class="col-md-4">
                @* Phần Upload Hình Ảnh *@
                <div class="card mb-3 shadow-sm">
                    <div class="card-header bg-primary text-white">Hình ảnh quán ăn</div>
                    <div class="card-body">
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        <small class="text-muted d-block mt-2">Hỗ trợ: .jpg, .png, .webp (Tối đa 5MB)</small>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label class="fw-bold">Phân loại quán</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="fw-bold">Vĩ độ (Latitude)</label>
                <input type="text" name="Latitude" class="form-control" placeholder="10.758..." />
            </div>
            <div class="col-md-4 mb-3">
                <label class="fw-bold">Kinh độ (Longitude)</label>
                <input type="text" name="Longitude" class="form-control" placeholder="106.705..." />
            </div>
            <div class="col-md-4 mb-3">
                <label class="fw-bold">Bán kính kích hoạt (mét)</label>
                <input type="number" name="TriggerRadius" class="form-control" value="30" />
            </div>
        </div>

        <div class="form-group mb-3">
            <label class="fw-bold">Địa chỉ số nhà</label>
            <input type="text" name="Address" class="form-control" placeholder="Ví dụ: 534 Vĩnh Khánh, Quận 4" />
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary px-4">Lưu địa điểm</button>
            <a href="/POI" class="btn btn-outline-secondary">Hủy bỏ</a>
        </div>
    </form>
</div>