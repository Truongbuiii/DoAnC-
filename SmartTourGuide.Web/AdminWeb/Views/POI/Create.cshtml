@model AdminWeb.Models.POI

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
    body { background-color: #f8fafc; font-family: 'Plus Jakarta Sans', sans-serif; }
    .form-container { max-width: 1100px; margin: 30px auto; }
    .card-custom { border: none; border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.05); background: white; overflow: hidden; }
    .card-header-custom { background: #0f172a; color: white; padding: 25px; border: none; }
    .form-label { font-weight: 700; color: #334155; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 8px; }
    .form-control, .form-select { border-radius: 12px; border: 1px solid #e2e8f0; padding: 12px 15px; }
    .lang-section { background: #fcfdfe; border-radius: 16px; padding: 20px; border: 1px solid #f1f5f9; margin-bottom: 20px; }
    .btn-save { background: #0f172a; color: white; border-radius: 12px; padding: 14px 40px; font-weight: 700; border: none; transition: 0.3s; }
    .btn-save:hover { background: #1e293b; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
    #map-picker { height: 400px; border-radius: 16px; border: 1px solid #e2e8f0; }
</style>

<div class="container form-container">
    <div class="card card-custom">
        <div class="card-header-custom d-flex align-items-center">
            <i class="bi bi-geo-fill fs-3 me-3 text-info"></i>
            <div>
                <h4 class="mb-0 fw-bold">Thêm Địa Điểm Mới</h4>
                <small class="text-info opacity-75">Quản trị Phố Vĩnh Khánh</small>
            </div>
        </div>

        <div class="card-body p-4 p-md-5">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                
                <div class="row mb-4">
                    <div class="col-md-5">
                        <label class="form-label">Tên địa điểm</label>
                        <input asp-for="Name" class="form-control" placeholder="" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Danh mục</label>
                        <select asp-for="Category" class="form-select" required>
                           
    <option value="Quán ốc">Quán ốc</option>
    <option value="Hải sản">Hải sản</option>
    <option value="Lẩu dê">Lẩu dê</option>
    <option value="Món lẩu">Món lẩu</option>
    <option value="Đồ Nhật">Đồ Nhật</option>
    <option value="Ăn vặt">Ăn vặt / Ăn nhẹ</option>
    <option value="Điểm tham quan">Điểm tham quan</option>
                        </select>
                    </div>
                    <div class="col-md-4">
    <label class="form-label text-primary">Gán chủ sở hữu</label>
    <div class="input-group">
        <select asp-for="OwnerUsername" class="form-select border-primary" asp-items="ViewBag.OwnerList">
            <option value="">-- Thuộc về hệ thống --</option>
        </select>

        <a asp-action="Create" asp-controller="Admins" class="btn btn-primary" title="Tạo tài khoản mới">
            <i class="bi bi-person-plus-fill"></i>
        </a>
    </div>
    <small class="text-muted" style="font-size: 0.7rem;">Hệ thống tự chọn nếu vừa tạo tài khoản.</small>
</div>
                </div>

                <div class="row">
                    <div class="col-lg-6">
                        <div class="lang-section shadow-sm">
                            <label class="form-label text-primary">Nội dung thuyết minh (VI)</label>
                            <textarea asp-for="DescriptionVi" class="form-control" rows="8" placeholder="Nhập bài giới thiệu..."></textarea>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Hình ảnh đại diện</label>
                            <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="lang-section shadow-sm">
                            <div id="map-picker"></div>
                            <div class="row g-2 mt-3">
                                <div class="col-6">
                                    <label class="small fw-bold text-muted">Vĩ độ</label>
                                    <input asp-for="Latitude" id="lat-input" class="form-control form-control-sm bg-light" readonly />
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold text-muted">Kinh độ</label>
                                    <input asp-for="Longitude" id="lon-input" class="form-control form-control-sm bg-light" readonly />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-between pt-4 border-top">
                    <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary fw-bold">
                        <i class="bi bi-arrow-left me-2"></i>Danh sách
                    </a>
                    <button type="submit" class="btn-save shadow">
                        <i class="bi bi-cloud-check-fill me-2"></i>Lưu Địa Điểm
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    var initLat = 10.761858; var initLon = 106.702236;
    var map = L.map('map-picker').setView([initLat, initLon], 18);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(map);
    var marker = L.marker([initLat, initLon], { draggable: true }).addTo(map);
    
    map.on('click', function(e) { marker.setLatLng(e.latlng); updateInputs(e.latlng.lat, e.latlng.lng); });
    marker.on('dragend', function(e) { var pos = marker.getLatLng(); updateInputs(pos.lat, pos.lng); });

    function updateInputs(lat, lng) { 
        document.getElementById('lat-input').value = lat.toFixed(6); 
        document.getElementById('lon-input').value = lng.toFixed(6); 
    }
    updateInputs(initLat, initLon);
</script>