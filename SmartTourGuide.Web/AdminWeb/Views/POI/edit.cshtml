@model AdminWeb.Models.POI

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
    .edit-container { background-color: #f8f9fa; padding: 30px; border-radius: 20px; }
    .card-custom { border: none; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); background: #fff; margin-bottom: 25px; }
    .header-gold { background: linear-gradient(45deg, #f6c23e, #f4b619); color: #fff; padding: 20px; border-radius: 15px 15px 0 0; }
    .form-label-custom { font-weight: 700; color: #4e73df; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 8px; display: block; }
    .form-control-custom { border-radius: 10px; border: 1px solid #d1d3e2; padding: 12px; transition: 0.3s; width: 100%; }
    .form-control-custom:focus { border-color: #f6c23e; box-shadow: 0 0 8px rgba(246, 194, 62, 0.2); outline: none; }
    .img-preview { width: 100%; max-height: 200px; object-fit: cover; border-radius: 12px; border: 3px solid #f8f9fc; }
    .btn-update { background: #f6c23e; color: #fff; font-weight: 700; border: none; padding: 15px 40px; border-radius: 12px; transition: 0.3s; width: 100%; }
    .btn-update:hover { background: #e0ac1f; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(246, 194, 62, 0.3); }
    .btn-back { color: #858796; text-decoration: none; font-weight: 600; transition: 0.2s; display: block; text-align: center; margin-top: 15px; }
    .btn-back:hover { color: #4e73df; }
    .nav-tabs-custom { border-bottom: 2px solid #eaecf4; margin-bottom: 0; }
    .nav-tabs-custom .nav-link { color: #858796; font-weight: 600; border: none; border-bottom: 3px solid transparent; padding: 12px 20px; transition: 0.2s; }
    .nav-tabs-custom .nav-link:hover { color: #f6c23e; border-bottom-color: #fce8b2; }
    .nav-tabs-custom .nav-link.active { color: #f6c23e; border-bottom-color: #f6c23e; background: transparent; }
    .tab-content-custom { background: #fffdf5; border: 1px solid #eaecf4; border-top: none; border-radius: 0 0 12px 12px; padding: 25px; }
</style>

<div class="container py-5">
    <div class="edit-container shadow-sm">
        <div class="d-flex align-items-center mb-4">
            <div class="bg-warning p-3 rounded-circle me-3 shadow-sm">
                <i class="bi bi-pencil-square text-white fs-4"></i>
            </div>
            <div>
                <h2 class="fw-bold text-dark mb-0">Chỉnh sửa địa điểm</h2>
                <p class="text-muted mb-0">Cập nhật thông tin và kịch bản thuyết minh (TTS)</p>
            </div>
        </div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="PoiId" />
            <input type="hidden" asp-for="ImageSource" />

            <!-- ROW 1: Thuyết minh + Hình ảnh/Phân quyền -->
            <div class="row">
                <div class="col-lg-8">
                  <div class="card-custom p-4">
    <div class="mb-4">
        <label class="form-label-custom">Tên địa điểm (Chính)</label>
        <input asp-for="Name" class="form-control-custom fs-5 fw-bold text-primary" required placeholder="Nhập tên quán..." />
    </div>

    <div class="border-bottom pb-2 mb-3">
        <h5 class="fw-bold text-secondary mb-0"><i class="bi bi-translate me-2"></i>Thuyết minh</h5>
    </div>

    <div class="mb-3">
        <label class="form-label-custom text-danger">Nội dung thuyết minh (Tiếng Việt)</label>
        <textarea asp-for="DescriptionVi" id="desc-vi" class="form-control-custom" rows="6"
                  placeholder="Nhập nội dung thuyết minh tiếng Việt..."></textarea>
        <small class="text-muted fst-italic">
            <i class="bi bi-info-circle"></i> App sẽ tự động dịch sang 4 ngôn ngữ khi hiển thị cho du khách.
        </small>
    </div>
</div>
                </div>

                <div class="col-lg-4">
                    <div class="card-custom">
                        <div class="header-gold">
                            <i class="bi bi-image me-2"></i>Hình ảnh & Phân quyền
                        </div>
                        <div class="p-4">
                            <div class="text-center mb-3">
                                @if (!string.IsNullOrEmpty(Model.ImageSource)) {
                                    <img src="/images/@Model.ImageSource" class="img-preview shadow-sm" />
                                } else {
                                    <div class="p-5 bg-light rounded text-muted">Chưa có ảnh</div>
                                }
                            </div>
                            <label class="form-label-custom mt-2">Thay đổi ảnh mới</label>
                            <input type="file" name="imageFile" class="form-control mb-3" accept="image/*" />

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="mb-3 pt-3 border-top">
                                    <label class="form-label-custom text-success"><i class="bi bi-person-badge me-1"></i>Giao quyền Chủ Quán</label>
                                    <select asp-for="OwnerUsername" class="form-control-custom border-success" asp-items="ViewBag.OwnerList">
                                        <option value="">-- Thuộc quản lý Admin --</option>
                                    </select>
                                    <small class="text-muted">Chọn tài khoản sẽ được quyền sửa quán này</small>
                                </div>
                            }
                            else
                            {
                                <input type="hidden" asp-for="OwnerUsername" />
                            }

                            <label class="form-label-custom mt-2">Phân loại quán</label>
                            <select asp-for="Category" class="form-control-custom bg-light">
                                <option value="Quán ốc">Quán ốc</option>
                                <option value="Lẩu dê">Lẩu dê</option>
                                <option value="Hải sản">Hải sản</option>
                                <option value="Điểm tham quan">Điểm tham quan</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ROW 2: GPS MAP PICKER - FULL WIDTH -->
            <div class="card-custom p-4">
                <label class="form-label-custom">
                    <i class="bi bi-geo-alt-fill me-2"></i>Vị trí GPS — Click hoặc kéo marker để chọn tọa độ
                </label>
                <div id="map-picker" style="height:450px;border-radius:10px;margin-bottom:16px;border:1px solid #d1d3e2;width:100%;"></div>
                <small class="text-muted d-block mb-3">
                    <i class="bi bi-info-circle"></i> Click trên bản đồ hoặc kéo marker để cập nhật tọa độ
                </small>
                <div class="row">
                    <div class="col-md-4">
                        <small class="text-muted fw-bold">Vĩ độ (Latitude)</small>
                        <input asp-for="Latitude" id="lat-input" class="form-control-custom font-monospace" required />
                    </div>
                    <div class="col-md-4">
                        <small class="text-muted fw-bold">Kinh độ (Longitude)</small>
                        <input asp-for="Longitude" id="lon-input" class="form-control-custom font-monospace" required />
                    </div>
                    <div class="col-md-4">
                        <small class="text-muted text-danger fw-bold">Bán kính kích hoạt (m)</small>
                        <input asp-for="TriggerRadius" class="form-control-custom" />
                    </div>
                </div>
            </div>

            <!-- NÚT LƯU -->
            <button type="submit" class="btn-update shadow mt-2">
                <i class="bi bi-floppy-fill me-2"></i>Lưu thay đổi
            </button>
            <a asp-action="Index" class="btn-back">
                <i class="bi bi-arrow-left me-1"></i>Hủy bỏ & Quay lại
            </a>

        </form>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    var initLat = parseFloat(document.getElementById('lat-input').value) || 10.760719;
    var initLon = parseFloat(document.getElementById('lon-input').value) || 106.703297;

    var map = L.map('map-picker').setView([initLat, initLon], 17);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; OpenStreetMap &copy; CARTO',
        subdomains: 'abcd',
        maxZoom: 20
    }).addTo(map);

    var marker = L.marker([initLat, initLon], { draggable: true }).addTo(map);

    map.on('click', function(e) {
        marker.setLatLng(e.latlng);
        updateInputs(e.latlng.lat, e.latlng.lng);
    });

    marker.on('dragend', function(e) {
        var pos = marker.getLatLng();
        updateInputs(pos.lat, pos.lng);
    });

    document.getElementById('lat-input').addEventListener('change', moveMarker);
    document.getElementById('lon-input').addEventListener('change', moveMarker);

    function updateInputs(lat, lng) {
        document.getElementById('lat-input').value = lat.toFixed(6);
        document.getElementById('lon-input').value = lng.toFixed(6);
    }

    function moveMarker() {
        var lat = parseFloat(document.getElementById('lat-input').value);
        var lon = parseFloat(document.getElementById('lon-input').value);
        if (!isNaN(lat) && !isNaN(lon)) {
            marker.setLatLng([lat, lon]);
            map.setView([lat, lon], 17);
        }
    }
</script>