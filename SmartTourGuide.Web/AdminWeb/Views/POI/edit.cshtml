@model AdminWeb.Models.POI

<div class="container mt-4">
    <h2 class="text-warning"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa điểm thuyết minh</h2>
    <hr />

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="PoiId" />

        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    <label class="fw-bold">Tên địa điểm</label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="fw-bold">Nội dung thuyết minh (TTS)</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                </div>
            </div>

            <div class="col-md-4 text-center">
                @* Xem trước ảnh hiện tại *@
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-light fw-bold">Ảnh hiện tại</div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.ImageSource))
                        {
                            <img src="/images/@Model.ImageSource" class="img-fluid rounded border shadow-sm" style="max-height: 200px;" />
                        }
                        else
                        {
                            <div class="p-4 bg-light text-muted border border-dashed">Chưa có ảnh</div>
                        }
                        <div class="mt-3">
                            <label class="form-label text-primary small fw-bold">Thay đổi ảnh mới:</label>
                            <input type="file" name="imageFile" class="form-control form-control-sm" accept="image/*" />
                        </div>
                    </div>
                </div>

                <div class="mb-3 text-start">
                    <label class="fw-bold">Phân loại quán</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
                </div>
            </div>
        </div>

        @* Thông tin Location liên kết *@
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="fw-bold">Vĩ độ (Latitude)</label>
                <input type="text" name="Latitude" value="@Model.Location?.Latitude" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="fw-bold">Kinh độ (Longitude)</label>
                <input type="text" name="Longitude" value="@Model.Location?.Longitude" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="fw-bold">Bán kính (mét)</label>
                <input type="number" name="TriggerRadius" value="@Model.Location?.TriggerRadius" class="form-control" />
            </div>
        </div>

        <div class="mb-3">
            <label class="fw-bold">Địa chỉ số nhà</label>
            <input type="text" name="Address" value="@Model.Location?.Address" class="form-control" />
        </div>

        <div class="mt-4 pb-5">
            <button type="submit" class="btn btn-success px-4">Cập nhật thay đổi</button>
            <a href="/POI" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </form>
</div>