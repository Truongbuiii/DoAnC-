@model AdminWeb.Models.POI

<div class="container mt-4">
    <h2 class="text-warning"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa địa điểm</h2>
    <hr />

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @* QUAN TRỌNG: Phải có 2 dòng ẩn này để máy biết đang sửa quán nào *@
        <input type="hidden" asp-for="PoiId" />
        <input type="hidden" asp-for="LocationId" />
        <input type="hidden" asp-for="ImageSource" /> @* Giữ lại tên ảnh cũ nếu không đổi *@

        <div class="row">
            <div class="col-md-8">
                <div class="form-group mb-3">
                    <label class="fw-bold">Tên địa điểm</label>
                    <input asp-for="Name" class="form-control" />
                </div>
                <div class="form-group mb-3">
                    <label class="fw-bold">Nội dung thuyết minh (TTS)</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card mb-3 shadow-sm">
                    <div class="card-header bg-warning text-dark fw-bold">Thay đổi hình ảnh</div>
                    <div class="card-body text-center">
                        @if (!string.IsNullOrEmpty(Model.ImageSource)) {
                            <img src="/images/@Model.ImageSource" class="img-thumbnail mb-2" style="height:150px" />
                        }
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label class="fw-bold">Phân loại quán</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="fw-bold">Vĩ độ (Latitude)</label>
                <input type="text" name="Latitude" class="form-control" value="@Model.Location?.Latitude" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="fw-bold">Kinh độ (Longitude)</label>
                <input type="text" name="Longitude" class="form-control" value="@Model.Location?.Longitude" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="fw-bold">Bán kính (mét)</label>
                <input type="number" name="TriggerRadius" class="form-control" value="@Model.Location?.TriggerRadius" />
            </div>
        </div>

        <div class="form-group mb-3">
            <label class="fw-bold">Địa chỉ số nhà</label>
            <input type="text" name="Address" class="form-control" value="@Model.Location?.Address" />
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-warning px-4 fw-bold">Cập nhật thay đổi</button>
            <a href="/POI" class="btn btn-outline-secondary">Hủy bỏ</a>
        </div>
    </form>
</div>