@model IEnumerable<AdminWeb.Models.Audio>

@{
    ViewData["Title"] = "Quản lý kịch bản Audio";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* Đồng bộ Font chữ chung */
    body { background-color: #f4f7f6; font-family: 'Inter', sans-serif; }
    
    /* --- HEADER CHUẨN --- */
    .header-banner {
        background: white; padding: 25px; border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-left: 6px solid #4e73df; margin-bottom: 25px;
    }
    .title-main { font-weight: 800; color: #2d3748; font-size: 1.5rem; letter-spacing: -0.5px; }
    
    /* --- BẢNG DỮ LIỆU (KẺ ĐẬM THEO Ý TÀI) --- */
    .audio-container { 
        background: white; border-radius: 20px; 
        box-shadow: 0 10px 30px rgba(0,0,0,0.08); 
        border: 2px solid #dee2e6; overflow: hidden;
    }

    .table thead th { 
        background-color: #4e73df; color: white; font-weight: 700; 
        text-transform: uppercase; font-size: 0.75rem; padding: 18px; 
        border: 1px solid #3659c2 !important; letter-spacing: 0.5px;
    }
    .table td { border: 1px solid #dee2e6 !important; vertical-align: middle; }
    .table tbody tr:hover { background-color: #f8faff !important; }

    /* --- THANH CUỘN CHO KỊCH BẢN DÀI --- */
    .script-box { 
        max-height: 85px; 
        overflow-y: auto; 
        padding-right: 8px; 
        font-size: 0.85rem; 
        line-height: 1.6; 
        color: #4a5568; 
    }
    .script-box::-webkit-scrollbar { width: 5px; }
    .script-box::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 10px; }
    .script-box::-webkit-scrollbar-thumb { background: #cbd5e0; border-radius: 10px; }
    .script-box::-webkit-scrollbar-thumb:hover { background: #a0aec0; }

    /* --- BADGE NGÔN NGỮ --- */
    .lang-badge { font-weight: 800; font-size: 0.75rem; padding: 6px 12px; border-radius: 8px; display: inline-block; text-align: center; min-width: 55px; }
    .lang-vn { background-color: #ffe5e5; color: #e74a3b; border: 1px solid #ffcccc; }
    .lang-en { background-color: #e5f0ff; color: #4e73df; border: 1px solid #cce0ff; }
    .lang-zh { background-color: #fff3cd; color: #f6c23e; border: 1px solid #ffeeba; }
    .lang-ko { background-color: #e3f2fd; color: #36b9cc; border: 1px solid #b8e2ef; }
    .lang-ja { background-color: #f8f9fc; color: #5a5c69; border: 1px solid #eaecf4; }

    /* --- NÚT THAO TÁC (SỬA/XÓA) --- */
    .action-btn {
        width: 36px; height: 36px; border-radius: 10px;
        display: inline-flex; align-items: center; justify-content: center;
        border: 1px solid #edf2f7; background: white; transition: 0.2s; text-decoration: none;
    }
    .btn-edit { color: #4e73df; }
    .btn-edit:hover { background: #4e73df; color: white !important; }
    .btn-delete { color: #e74a3b; }
    .btn-delete:hover { background: #e74a3b; color: white !important; }

    /* --- NÚT TẠO MỚI --- */
    .btn-create-audio {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
        color: white !important; padding: 12px 24px; border-radius: 12px;
        font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        transition: 0.3s; box-shadow: 0 4px 12px rgba(78, 115, 223, 0.3);
    }
    .btn-create-audio:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(78, 115, 223, 0.4); filter: brightness(1.1); }
</style>

<div class="container-fluid py-4 px-4">
    
    <div class="header-banner shadow-sm mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-3">
                    <h1 class="title-main mb-0">Quản Lý Nội Dung Thuyết Minh (TTS)</h1>
                </div>
                <p class="text-muted mt-2 mb-0" style="font-size: 0.9rem;">
                    Danh sách các kịch bản đa ngôn ngữ dùng để phát tự động cho ứng dụng di động.
                </p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                @* PHÂN QUYỀN: CHỈ ADMIN MỚI THẤY NÚT TẠO MỚI *@
                @if (User.IsInRole("Admin"))
                {
                    <a class="btn-create-audio" asp-action="Create">
                        <i class="bi bi-plus-lg" style="font-size: 1.2rem;"></i> TẠO MỚI KỊCH BẢN
                    </a>
                }
                else
                {
                    <span class="badge bg-info text-dark p-2 border border-info shadow-sm" style="font-size: 0.85rem;">
                        <i class="bi bi-person-check-fill me-1"></i> Quyền Chủ Sở Hữu
                    </span>
                }
            </div>
        </div>
    </div>

    <div class="audio-container">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
               <thead>
                    <tr>
                        <th style="width: 20%;">TIÊU ĐỀ & MÔ TẢ</th>
                        <th class="text-center" style="width: 10%;">NGÔN NGỮ</th>
                        <th style="width: 40%;">NỘI DUNG KỊCH BẢN (TEXT)</th>
                        <th style="width: 20%;">THUỘC ĐỊA ĐIỂM (POI)</th>
                        <th class="text-center" style="width: 10%;">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-3">
                                <div class="fw-bold text-dark" style="font-size: 0.95rem;">@item.AudioName</div>
                                @if(!string.IsNullOrEmpty(item.Description)){
                                    <small class="text-muted d-block mt-1">@item.Description</small>
                                }
                            </td>
                            
                            <td class="text-center">
                                <span class="lang-badge @GetLangClass(item.Language)">
                                    @(item.Language ?? "N/A")
                                </span>
                            </td>
                            
                            <td class="px-3">
                                @if (!string.IsNullOrEmpty(item.Script))
                                {
                                    <div class="script-box border p-2 rounded bg-light">
                                        @item.Script
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-light text-secondary border fst-italic">Chưa có nội dung</span>
                                }
                            </td>
                            
                            <td class="px-3">
                                <div class="d-inline-flex align-items-center bg-light border px-2 py-1 rounded">
                                    <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                                    <span class="fw-bold text-dark" style="font-size: 0.85rem;">@(item.Poi?.Name ?? "Chưa gắn POI")</span>
                                </div>
                            </td>
                            
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a class="action-btn btn-edit shadow-sm" asp-action="Edit" asp-route-id="@item.AudioId" title="Sửa">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <button type="button" class="action-btn btn-delete shadow-sm" 
                                            onclick="confirmDelete('@item.AudioId', '@item.AudioName')" title="Xóa">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    // Hàm C# hỗ trợ tự động tô màu cho thẻ Ngôn ngữ
    public string GetLangClass(string lang)
    {
        if (string.IsNullOrEmpty(lang)) return "lang-ja";
        return lang.ToUpper() switch
        {
            "VN" => "lang-vn",
            "EN" => "lang-en",
            "ZH" => "lang-zh",
            "KO" => "lang-ko",
            "JA" => "lang-ja",
            _ => "lang-ja"
        };
    }
}

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: "Bạn có chắc muốn xóa kịch bản: " + name + "? Hệ thống không thể khôi phục lại!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e74a3b',
                cancelButtonColor: '#858796',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("Delete", "Audios")/' + id;
                }
            })
        }
    </script>
}