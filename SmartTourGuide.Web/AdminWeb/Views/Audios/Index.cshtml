@model IEnumerable<AdminWeb.Models.Audio>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
    /* Style đồng bộ với trang POI */
    .header-banner {
        background: white; padding: 25px; border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-left: 6px solid #4e73df; margin-bottom: 25px;
    }
    .title-main { font-weight: 800; color: #2d3748; font-size: 1.5rem; }
    
    .audio-container { 
        background: white; border-radius: 20px; 
        box-shadow: 0 10px 30px rgba(0,0,0,0.08); 
        border: 2px solid #dee2e6; overflow: hidden;
    }

    .table thead th { 
        background-color: #4e73df; color: white; font-weight: 700; 
        text-transform: uppercase; font-size: 0.75rem; padding: 18px; 
        border: 1px solid #3659c2 !important;
    }

    .table td { border: 1px solid #dee2e6 !important; vertical-align: middle; }

    .btn-create-audio {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
        color: white !important; padding: 10px 20px; border-radius: 12px;
        font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        transition: 0.3s;
    }
    .btn-create-audio:hover { transform: translateY(-2px); filter: brightness(1.1); }
</style>

<div class="container-fluid py-4 px-4">
    <div class="header-banner shadow-sm mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="title-main mb-0">Quản Lý Nội Dung Thuyết Minh (TTS)</h1>
                <p class="text-muted mt-2 mb-0">Danh sách các kịch bản đa ngôn ngữ dùng để phát tự động (Text-to-Speech) cho ứng dụng di động.</p>
            </div>
            <div class="col-md-4 text-md-end">
                <a class="btn-create-audio shadow" asp-action="Create">
                    <i class="bi bi-plus-circle-fill"></i> TẠO MỚI KỊCH BẢN
                </a>
            </div>
        </div>
    </div>

    <div class="audio-container">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
               <thead class="bg-primary text-white">
                    <tr>
                        <th>TIÊU ĐỀ & MÔ TẢ</th>
                        <th class="text-center">NGÔN NGỮ</th>
                        <th>NỘI DUNG KỊCH BẢN (TEXT)</th>
                        <th>THUỘC ĐỊA ĐIỂM (POI)</th>
                        <th class="text-center">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-3">
                                <div class="fw-bold text-dark">@item.AudioName</div>
                                <small class="text-muted">@item.Description</small>
                            </td>
                            <td class="text-center">
                                <span class="badge @(item.Language == "VN" ? "bg-danger" : "bg-primary")">
                                    @item.Language
                                </span>
                            </td>
                            
                          <td class="px-3 text-wrap" style="max-width: 400px; line-height: 1.5;">
    @if (!string.IsNullOrEmpty(item.FilePath))
    {
        <span class="text-dark">
            @item.FilePath
        </span>
    }
    else
    {
        <span class="text-muted small fst-italic">Chưa có nội dung</span>
    }
</td>
                            <td class="px-3">
                                <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                <strong>@(item.Poi?.Name ?? "N/A")</strong>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a class="btn btn-outline-primary btn-sm shadow-sm" asp-action="Edit" asp-route-id="@item.AudioId">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <button type="button" class="btn btn-outline-danger btn-sm shadow-sm" 
                                            onclick="confirmDelete('@item.AudioId', '@item.AudioName')">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>