@{
    ViewData["Title"] = "Thống kê & Phân tích";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Báo Cáo Phân Tích</h2>
            <p class="text-muted small">Dữ liệu thực tế từ lượt truy cập của khách du lịch</p>
        </div>
        <button class="btn btn-outline-primary rounded-pill px-4" onclick="window.print()">
            <i class="bi bi-printer me-2"></i>Xuất báo cáo
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3 rounded-4">
                <div class="small fw-bold">Tổng lượt truy cập</div>
                <div class="h3 fw-bold my-2">@(((int[])ViewBag.PoiCounts).Sum())</div>
                <div class="small opacity-75">Tăng 12% so với tháng trước</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-white p-3 rounded-4">
                <div class="small fw-bold text-muted">Ngôn ngữ phổ biến nhất</div>
                <div class="h3 fw-bold my-2 text-dark">@ViewBag.LangLabels[0]</div>
                <div class="small text-success fw-bold"><i class="bi bi-caret-up-fill"></i> @ViewBag.LangCounts[0] lượt</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-bar-chart-line me-2"></i>Top 5 Địa điểm được ghé thăm nhiều nhất</h6>
                </div>
                <div class="card-body">
                    <canvas id="poiChart" style="min-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-pie-chart me-2"></i>Cơ cấu Ngôn ngữ khách dùng</h6>
                </div>
                <div class="card-body d-flex align-items-center">
                    <canvas id="langChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Cấu hình Font mặc định cho biểu đồ
        Chart.defaults.font.family = "'Segoe UI', 'Roboto', sans-serif";

        // 1. BIỂU ĐỒ CỘT (Top 5 POIs)
        const ctxPoi = document.getElementById('poiChart').getContext('2d');
        new Chart(ctxPoi, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.PoiNames)),
                datasets: [{
                    label: 'Lượt ghé thăm',
                    data: @Html.Raw(Json.Serialize(ViewBag.PoiCounts)),
                    backgroundColor: 'rgba(13, 110, 253, 0.8)',
                    hoverBackgroundColor: '#0d6efd',
                    borderRadius: 8,
                    barThickness: 40
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, grid: { drawBorder: false } },
                    x: { grid: { display: false } }
                }
            }
        });

        // 2. BIỂU ĐỒ TRÒN (Ngôn ngữ)
        const ctxLang = document.getElementById('langChart').getContext('2d');
        new Chart(ctxLang, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.LangLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(ViewBag.LangCounts)),
                    backgroundColor: ['#0d6efd', '#ffc107', '#198754', '#dc3545', '#6610f2'],
                    hoverOffset: 10,
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                cutout: '70%',
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                }
            }
        });
    </script>
}