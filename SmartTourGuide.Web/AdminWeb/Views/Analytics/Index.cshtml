@{
    ViewData["Title"] = ViewBag.AnalyticsTitle;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">@ViewBag.AnalyticsTitle</h2>
            <p class="text-muted small">Dữ liệu thực tế từ lượt truy cập của khách du lịch</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="badge bg-success fs-6 px-3 py-2">
                ● LIVE — cập nhật sau <span id="refresh-countdown">10</span>s
            </span>
            <button class="btn btn-outline-primary rounded-pill px-4" onclick="window.print()">
                <i class="bi bi-printer me-2"></i> Xuất báo cáo
            </button>
        </div>
    </div>

    <div class="row mb-4">
        @* CỘT 1: TỔNG LƯỢT TRUY CẬP *@
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3 rounded-4 h-100">
                <div class="small fw-bold text-uppercase opacity-75">Tổng lượt truy cập</div>
                <div class="h3 fw-bold my-2">@ViewBag.TotalVisits</div>
                <div class="small opacity-75">
                    <i class="bi bi-graph-up-arrow"></i>
                    @(ViewBag.IsAdmin ? "Toàn phố Vĩnh Khánh" : "Tại quán của bạn")
                </div>
            </div>
        </div>

        @* CỘT 2: NGÔN NGỮ PHỔ BIẾN *@
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-white p-3 rounded-4 h-100">
                <div class="small fw-bold text-muted text-uppercase">Ngôn ngữ phổ biến nhất</div>
                @if (ViewBag.LangLabels != null && ViewBag.LangLabels.Length > 0)
                {
                    <div class="h3 fw-bold my-2 text-dark">@ViewBag.LangLabels[0]</div>
                    <div class="small text-success fw-bold">
                        <i class="bi bi-caret-up-fill"></i> @ViewBag.LangCounts[0] lượt sử dụng
                    </div>
                }
                else
                {
                    <div class="h3 fw-bold my-2 text-muted small italic">Chưa có dữ liệu</div>
                }
            </div>
        </div>
    </div>

    <div class="row">
        @* BIỂU ĐỒ CHÍNH (CỘT/ĐƯỜNG) *@
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold mb-0 text-dark">
                        <i class="bi bi-bar-chart-line me-2 text-primary"></i>
                        @(ViewBag.IsAdmin ? "Xếp hạng lượt khách giữa các địa điểm" : "Xu hướng lượt khách ghé quán theo thời gian")
                    </h6>
                </div>
                <div class="card-body">
                    <canvas id="poiChart" style="min-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        @* BIỂU ĐỒ TRÒN (NGÔN NGỮ) *@
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold mb-0 text-dark">
                        <i class="bi bi-pie-chart me-2 text-success"></i>Cơ cấu Ngôn ngữ khách dùng
                    </h6>
                </div>
                <div class="card-body d-flex align-items-center">
                    <canvas id="langChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        Chart.defaults.font.family = "'Inter', 'Segoe UI', sans-serif";

        // 1. BIỂU ĐỒ CỘT (HOẶC ĐƯỜNG)
        const ctxPoi = document.getElementById('poiChart').getContext('2d');
        const isAdmin = @Json.Serialize(ViewBag.IsAdmin);

        new Chart(ctxPoi, {
            type: isAdmin ? 'bar' : 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.PoiNames)),
                datasets: [{
                    label: '@Html.Raw(ViewBag.ChartLabel)',
                    data: @Html.Raw(Json.Serialize(ViewBag.PoiCounts)),
                    backgroundColor: isAdmin ? 'rgba(13, 110, 253, 0.8)' : 'rgba(13, 110, 253, 0.1)',
                    borderColor: '#0d6efd',
                    borderWidth: 3,
                    borderRadius: 8,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f0f0f0' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // 2. BIỂU ĐỒ TRÒN (Ngôn ngữ)
        const ctxLang = document.getElementById('langChart').getContext('2d');
        new Chart(ctxLang, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.LangLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(ViewBag.LangCounts)),
                    backgroundColor: ['#0d6efd', '#ffc107', '#198754', '#dc3545', '#6610f2'],
                    hoverOffset: 15,
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                cutout: '75%',
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 25 } }
                }
            }
        });
    </script>

    @* AUTO-REFRESH MỖI 10 GIÂY *@
    <script>
        var refreshSeconds = 10;
        var countdownEl = document.getElementById('refresh-countdown');

        setInterval(function () {
            refreshSeconds--;
            if (countdownEl) countdownEl.textContent = refreshSeconds;
            if (refreshSeconds <= 0) location.reload();
        }, 1000);
    </script>
}
