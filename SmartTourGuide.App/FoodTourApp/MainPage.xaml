<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.MainPage"
             BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Grid HeightRequest="130" BackgroundColor="#1F2937">
                <Ellipse Fill="#22F97316" WidthRequest="200" HeightRequest="200"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="0,-60,-40,0"/>
                <Ellipse Fill="#11F97316" WidthRequest="120" HeightRequest="120"
                         HorizontalOptions="End" VerticalOptions="End"
                         Margin="0,0,60,-40"/>
                <VerticalStackLayout Padding="24,40,24,20" Spacing="4"
                                     VerticalOptions="End">
                    <Label x:Name="LblWelcome" TextColor="#9CA3AF" FontSize="13"/>
                    <Label x:Name="LblTitle" TextColor="White" FontSize="22" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Grid>

            <Border Margin="16,-20,16,0" StrokeShape="RoundRectangle 20" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.2"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBannerTapped"/>
                </Border.GestureRecognizers>
                <Grid HeightRequest="120">
                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F97316" Offset="0"/>
                                <GradientStop Color="#EA580C" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <Ellipse Fill="#22FFFFFF" WidthRequest="120" HeightRequest="120"
                             HorizontalOptions="End" VerticalOptions="Center"
                             Margin="0,0,-30,0"/>
                    <VerticalStackLayout Padding="20" Spacing="4" VerticalOptions="Center">
                        <Label x:Name="LblTop10" TextColor="#FED7AA" FontSize="11" FontAttributes="Bold"/>
                        <Label x:Name="LblExplore" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                        <Label x:Name="LblSubtitle" TextColor="#FFEDD5" FontSize="12"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <VerticalStackLayout Padding="16,24,16,0" Spacing="12">
                <Label x:Name="LblTours" FontSize="17" FontAttributes="Bold" TextColor="#111827"/>
                <CollectionView x:Name="ToursList" HeightRequest="160"
                                SelectionMode="Single" SelectionChanged="OnTourSelected">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="260" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.15"/>
                                </Border.Shadow>
                                <Grid HeightRequest="160">
                                    <BoxView Color="#1F2937"/>
                                    <Image Source="{Binding ImageSource}" Aspect="AspectFill" Opacity="0.7"/>
                                    <BoxView>
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0"/>
                                                <GradientStop Color="#DD000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>
                                    <VerticalStackLayout VerticalOptions="End" Padding="14,10" Spacing="4">
                                        <Label Text="{Binding DisplayName}" TextColor="White"
                                               FontSize="15" FontAttributes="Bold"/>
                                        <Border BackgroundColor="#F97316"
                                                StrokeShape="RoundRectangle 6" Padding="6,2">
                                            <Label Text="{Binding Duration}" TextColor="White" FontSize="10"/>
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout Padding="16,24,16,16" Spacing="12">
                <Label x:Name="LblFeatured" FontSize="17" FontAttributes="Bold" TextColor="#1F2937"/>
                <CollectionView x:Name="FeaturedPoisList"
                                SelectionMode="Single" SelectionChanged="OnPoiSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12" StrokeShape="RoundRectangle 16"
                                    BackgroundColor="White" StrokeThickness="0">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                                </Border.Shadow>
                                <Grid ColumnDefinitions="90, *" Padding="12">
                                    <Image Grid.Column="0" Source="{Binding FullImageUrl}"
                                           Aspect="AspectFill" HeightRequest="80" WidthRequest="80">
                                        <Image.Clip>
                                            <RoundRectangleGeometry CornerRadius="12" Rect="0,0,80,80"/>
                                        </Image.Clip>
                                    </Image>
                                    <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0"
                                                         VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding DisplayName}" FontAttributes="Bold"
                                               FontSize="15" TextColor="#111827"/>

                                        <Border BackgroundColor="#FFF7ED"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="8,3" HorizontalOptions="Start">
                                            <Label Text="{Binding DisplayCategory}" FontSize="11"
                                                   TextColor="#F97316" FontAttributes="Bold"/>
                                        </Border>
                                        <Label x:Name="LblLocation" FontSize="11" TextColor="#9CA3AF"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>