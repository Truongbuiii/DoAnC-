<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.MainPage"
             BackgroundColor="#F9FAFB">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <VerticalStackLayout Spacing="5">
                <Label Text="Chào bạn, hôm nay ăn gì?" FontSize="14" TextColor="Gray"/>
                <Label Text="VĨNH KHÁNH FOOD" FontSize="26" FontAttributes="Bold" TextColor="#1F2937"/>
            </VerticalStackLayout>

            <Border StrokeShape="RoundRectangle 20" StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBannerTapped"/>
                </Border.GestureRecognizers>

                <Grid HeightRequest="160">
                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1F2937" Offset="0"/>
                                <GradientStop Color="#374151" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <Ellipse Fill="#22FF6B35" WidthRequest="150" HeightRequest="150"
                 HorizontalOptions="End" VerticalOptions="Start" Margin="0,-30,-30,0"/>
                    <VerticalStackLayout Padding="20" Spacing="8" VerticalOptions="Center">
                        <Label Text="🏆 Top 10 thế giới 2025" TextColor="#FF6B35"
                   FontSize="12" FontAttributes="Bold"/>
                        <Label Text="Phố ẩm thực Vĩnh Khánh" TextColor="White"
                   FontSize="20" FontAttributes="Bold"/>
                        <Label Text="Thiên đường ốc &amp; hải sản Quận 4" 
                   TextColor="#9CA3AF" FontSize="13"/>
                        <Border BackgroundColor="#FF6B35" StrokeShape="RoundRectangle 10"
                    Padding="12,6" HorizontalOptions="Start" Margin="0,5,0,0">
                            <Label Text="🗺️ Khám phá ngay" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                            
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="15">
                <Label Text="Địa điểm nổi bật" FontSize="18" FontAttributes="Bold" TextColor="#1F2937"/>
                <CollectionView x:Name="FeaturedPoisList" SelectionMode="Single" SelectionChanged="OnPoiSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,15" StrokeShape="RoundRectangle 15" BackgroundColor="White" StrokeThickness="0">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.1"/>
                                </Border.Shadow>
                                <Grid ColumnDefinitions="100, *" Padding="10">

                                    <Image Grid.Column="0"
                                           Source="{Binding FullImageUrl}" 
                                           Aspect="AspectFill" 
                                           HeightRequest="80" 
                                           WidthRequest="80">
                                        <Image.Clip>
                                            <RoundRectangleGeometry CornerRadius="10" Rect="0,0,80,80"/>
                                        </Image.Clip>
                                    </Image>

                                    <VerticalStackLayout Grid.Column="1" Margin="15,0" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" TextColor="#1F2937"/>
                                        <Label Text="{Binding Category}" FontSize="12" TextColor="Orange"/>
                                        <Label Text="📍 Quận 4, TP.HCM" FontSize="11" TextColor="Gray"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>