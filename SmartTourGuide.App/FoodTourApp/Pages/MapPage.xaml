<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.Pages.MapPage"
             BackgroundColor="#F9FAFB">

    <Grid RowDefinitions="Auto, Auto, *">

        <Border Grid.Row="0" BackgroundColor="White" StrokeThickness="0" HeightRequest="60">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*, Auto" Padding="20,0">
                <Label Text="📍 VĨNH KHÁNH TOUR" VerticalOptions="Center" FontAttributes="Bold" FontSize="18" TextColor="#1F2937"/>
                <Image Grid.Column="1" Source="notification_icon.png" WidthRequest="25" HeightRequest="25" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="15,10" StrokeShape="RoundRectangle 25" Padding="15,0" StrokeThickness="1" Stroke="#E5E7EB" BackgroundColor="White">
            <Entry x:Name="SearchEntry" Placeholder="Tìm quán ăn..." FontSize="14" TextChanged="OnSearchTextChanged"/>
        </Border>

        <Grid Grid.Row="2">
            <WebView x:Name="MapWebView" 
                     HorizontalOptions="FillAndExpand" 
                     VerticalOptions="FillAndExpand" />

            <ActivityIndicator x:Name="MapLoading" 
                               IsRunning="True" 
                               VerticalOptions="Center" 
                               HorizontalOptions="Center" 
                               Color="Orange" />

            <Border x:Name="PoiCard" VerticalOptions="End" HorizontalOptions="Center" 
                    Margin="15,20" Padding="15" BackgroundColor="White"
                    StrokeShape="RoundRectangle 20" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.2"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                    <Image x:Name="PoiImage" Source="cong_chao.jpg" Aspect="AspectFill" HeightRequest="80" WidthRequest="80">
                        <Image.Clip>
                            <RoundRectangleGeometry CornerRadius="12" Rect="0,0,80,80"/>
                        </Image.Clip>
                    </Image>

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label x:Name="CurrentPoiName" Text="Phố ẩm thực Vĩnh Khánh" FontSize="16" FontAttributes="Bold"/>
                        <Label x:Name="CategoryLabel" Text="KHÁM PHÁ" FontSize="11" TextColor="Orange"/>

                        <Label x:Name="StatusLabel" Text="Đang cập nhật GPS..." FontSize="11" TextColor="Gray"/>

                        <HorizontalStackLayout Spacing="8" Margin="0,5,0,0">
                            <Button Text="Dẫn đường" Clicked="OnNavigateClicked" BackgroundColor="#1F2937" TextColor="White" CornerRadius="15" HeightRequest="35" FontSize="11"/>
                            <Button Text="Yêu thích" Clicked="OnReplayClicked" BackgroundColor="Orange" TextColor="White" CornerRadius="15" HeightRequest="35" FontSize="11"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <CollectionView x:Name="PoisListView" IsVisible="False" SelectionMode="Single" SelectionChanged="OnPoiSelected" />

            <HorizontalStackLayout VerticalOptions="Start" HorizontalOptions="End" Margin="10" Spacing="5">
                <Button Text="Ốc Oanh" Clicked="SimulateOcOanh" Scale="0.8" BackgroundColor="#CCFFFFFF" TextColor="Black"/>
                <Button Text="Ốc Vũ" Clicked="SimulateOcVu" Scale="0.8" BackgroundColor="#CCFFFFFF" TextColor="Black"/>
                <Button Text="Reset" Clicked="SimulateReset" Scale="0.8" BackgroundColor="#CCFFFFFF" TextColor="Gray"/>
            </HorizontalStackLayout>
        </Grid>
    </Grid>
</ContentPage>