<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.Pages.MapPage"
             BackgroundColor="#F9FAFB">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- HEADER -->
        <Border Grid.Row="0" BackgroundColor="White" StrokeThickness="0" HeightRequest="60">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*, Auto, Auto" Padding="20,0">
                <Label Text="📍 VĨNH KHÁNH TOUR" VerticalOptions="Center"
                       FontAttributes="Bold" FontSize="18" TextColor="#1F2937"/>
                <Border Grid.Column="1" StrokeShape="RoundRectangle 15"
                        BackgroundColor="#F3F4F6" Padding="10,5"
                        Margin="0,0,10,0" VerticalOptions="Center">
                    <Picker x:Name="LanguagePicker" Title="🌐"
                            SelectedIndexChanged="OnLanguageChanged"
                            FontSize="14" TextColor="#1F2937" HorizontalOptions="Center">
                        <Picker.Items>
                            <x:String>🇻🇳 Tiếng Việt</x:String>
                            <x:String>🇺🇸 English</x:String>
                            <x:String>🇨🇳 中文</x:String>
                            <x:String>🇰🇷 한국어</x:String>
                            <x:String>🇯🇵 日本語</x:String>
                        </Picker.Items>
                    </Picker>
                </Border>
                <Image Grid.Column="2" Source="notification_icon.png"
                       WidthRequest="25" HeightRequest="25" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- SEARCH BAR -->
        <Border Grid.Row="1" Margin="15,10" StrokeShape="RoundRectangle 25"
                Padding="15,0" StrokeThickness="1" Stroke="#E5E7EB" BackgroundColor="White">
            <Entry x:Name="SearchEntry" Placeholder="Tìm quán ăn..."
                   FontSize="14" TextChanged="OnSearchTextChanged"/>
        </Border>

        <!-- MAP + CONTROLS -->
        <Grid Grid.Row="2">
            <WebView x:Name="MapWebView" HorizontalOptions="Fill" VerticalOptions="Fill"/>

            <ActivityIndicator x:Name="MapLoading" IsRunning="True"
                               VerticalOptions="Center" HorizontalOptions="Center" Color="Orange"/>

            <!-- POI CARD -->
            <Border x:Name="PoiCard" VerticalOptions="End" HorizontalOptions="Center"
                    Margin="15,20" Padding="15" BackgroundColor="White"
                    StrokeShape="RoundRectangle 20" StrokeThickness="0" IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.2"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                    <Image x:Name="PoiImage" Source="cong_chao.jpg" Aspect="AspectFill"
                           HeightRequest="80" WidthRequest="80">
                        <Image.Clip>
                            <RoundRectangleGeometry CornerRadius="12" Rect="0,0,80,80"/>
                        </Image.Clip>
                    </Image>

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <!-- ✅ 3 Label quan trọng -->
                        <Label x:Name="CurrentPoiName" Text="Phố ẩm thực Vĩnh Khánh"
                               FontSize="16" FontAttributes="Bold"/>
                        <Label x:Name="CategoryLabel" Text="KHÁM PHÁ"
                               FontSize="11" TextColor="Orange"/>
                        <Label x:Name="StatusLabel" Text="Đang cập nhật GPS..."
                               FontSize="11" TextColor="Gray"/>

                        <!-- ✅ 4 nút dạng Grid 2x2, không dùng FillAndExpand -->
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="6" Margin="0,5,0,0">
                            <Grid Grid.Row="0" ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Grid.Column="0" Text="🧭 Dẫn đường"
                                        Clicked="OnNavigateClicked"
                                        BackgroundColor="#1F2937" TextColor="White"
                                        CornerRadius="15" HeightRequest="35" FontSize="11"/>
                                <Button Grid.Column="1" Text="🔊 Nghe lại"
                                        Clicked="OnReplayClicked"
                                        BackgroundColor="Orange" TextColor="White"
                                        CornerRadius="15" HeightRequest="35" FontSize="11"/>
                            </Grid>
                            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button x:Name="BtnFavorite" Grid.Column="0"
                                        Text="🤍 Yêu thích" Clicked="OnToggleFavorite"
                                        BackgroundColor="#FF6B6B" TextColor="White"
                                        CornerRadius="15" HeightRequest="35" FontSize="11"/>
                                <Button Grid.Column="1" Text="📋 Chi tiết"
                                        Clicked="OnDetailClicked"
                                        BackgroundColor="#6B7280" TextColor="White"
                                        CornerRadius="15" HeightRequest="35" FontSize="11"/>
                            </Grid>
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- DANH SÁCH POI -->
            <CollectionView x:Name="PoisListView" IsVisible="False"
                            SelectionMode="Single" SelectionChanged="OnPoiSelected"/>

            <!-- NÚT SIMULATE -->
            <HorizontalStackLayout VerticalOptions="Start" HorizontalOptions="End"
                                   Margin="10" Spacing="5">
                <Button Text="Ốc Oanh" Clicked="SimulateOcOanh" Scale="0.8"
                        BackgroundColor="#CCFFFFFF" TextColor="Black"/>
                <Button Text="Ốc Vũ" Clicked="SimulateOcVu" Scale="0.8"
                        BackgroundColor="#CCFFFFFF" TextColor="Black"/>
                <Button Text="Reset" Clicked="SimulateReset" Scale="0.8"
                        BackgroundColor="#CCFFFFFF" TextColor="Gray"/>
            </HorizontalStackLayout>
        </Grid>
    </Grid>
</ContentPage>