<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.Pages.FavoritesPage"
             Title="Địa điểm yêu thích">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="DANH SÁCH YÊU THÍCH" FontSize="20" FontAttributes="Bold"/>

        <CollectionView x:Name="FavoritesList">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,100">
                    <Label Text="💔" FontSize="50" HorizontalOptions="Center"/>
                    <Label Text="Bạn chưa lưu quán nào cả!" TextColor="Gray" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>