<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.Pages.FavoritesPage"
             BackgroundColor="#F3F4F6">

    <VerticalStackLayout Padding="16" Spacing="12">

        <Label x:Name="LblTitle" FontSize="20" FontAttributes="Bold"
               TextColor="#111827" Margin="4,8,0,4"/>

        <CollectionView x:Name="FavoritesList"
                        SelectionMode="Single"
                        SelectionChanged="OnPoiSelected">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center" Margin="0,80" Spacing="12">
                    <Label Text="💔" FontSize="50" HorizontalOptions="Center"/>
                    <Label x:Name="LblEmpty" TextColor="#9CA3AF" FontSize="15"
                           HorizontalOptions="Center"/>
                    <Label x:Name="LblEmptySub" TextColor="#D1D5DB" FontSize="13"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10" StrokeThickness="0"
                            StrokeShape="RoundRectangle 14" BackgroundColor="White">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14" ColumnSpacing="12">

                            <!-- ĐỔI TỪ ICON → ẢNH THẬT -->
                            <Image Grid.Column="0"
           Source="{Binding FullImageUrl}"
           Aspect="AspectFill"
           HeightRequest="56"
           WidthRequest="56">
                                <Image.Clip>
                                    <RoundRectangleGeometry CornerRadius="10" Rect="0,0,56,56"/>
                                </Image.Clip>
                            </Image>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                <Label Text="{Binding Name}" FontSize="15"
               FontAttributes="Bold" TextColor="#111827"/>
                                <Label Text="{Binding Category}" FontSize="12" TextColor="#F97316"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="2" Text="🗑️" FontSize="18"
            BackgroundColor="Transparent" TextColor="#EF4444"
            Clicked="OnRemoveFavorite"
            CommandParameter="{Binding PoiId}"
            VerticalOptions="Center"
            WidthRequest="44" HeightRequest="44"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>