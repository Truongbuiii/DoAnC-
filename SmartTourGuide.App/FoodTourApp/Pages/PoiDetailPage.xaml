<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.Pages.PoiDetailPage"
             Title="Chi tiết địa điểm"
             BackgroundColor="#F9FAFB">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <AbsoluteLayout HeightRequest="280">
                <!-- Nền xám -->
                <BoxView Color="#1F2937"
             AbsoluteLayout.LayoutFlags="All"
             AbsoluteLayout.LayoutBounds="0,0,1,1"/>

                <!-- Ảnh -->
                <Image x:Name="MainImage"
       Source="{Binding FullImageUrl}"
       Aspect="AspectFill"
       AbsoluteLayout.LayoutFlags="All"
       AbsoluteLayout.LayoutBounds="0,0,1,1"/>

                <!-- Overlay tối -->
                <BoxView Color="#66000000"
             AbsoluteLayout.LayoutFlags="All"
             AbsoluteLayout.LayoutBounds="0,0,1,1"/>

                <!-- Tên + Category -->
                <VerticalStackLayout Spacing="5"
                         AbsoluteLayout.LayoutFlags="WidthProportional,YProportional"
                         AbsoluteLayout.LayoutBounds="20,0.95,1,AutoSize">
                    <Label x:Name="DetailName" TextColor="White" FontSize="26" FontAttributes="Bold"/>
                    <Label x:Name="DetailCategory" TextColor="Orange" FontSize="14" FontAttributes="Bold"/>
                </VerticalStackLayout>

                <!-- Nút back -->
                <ImageButton Source="back_icon.png" WidthRequest="32" HeightRequest="32"
                 Clicked="OnBackClicked" BackgroundColor="#66000000"
                 AbsoluteLayout.LayoutBounds="15,45,32,32"
                 AbsoluteLayout.LayoutFlags="None"/>
            </AbsoluteLayout>

            <!-- MÔ TẢ -->
            <Border Margin="20,-20,20,0" Padding="20" BackgroundColor="White"
                    StrokeShape="RoundRectangle 20" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,5" Radius="15" Opacity="0.1"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Giới thiệu &amp; Lịch sử" FontSize="17"
                           FontAttributes="Bold" TextColor="#1F2937"/>
                    <Label x:Name="DetailDescription" FontSize="14"
                           LineHeight="1.6" TextColor="#4B5563"/>
                </VerticalStackLayout>
            </Border>

            <!-- MÓN ĂN -->
            <Border Margin="20,15,20,0" Padding="15"
                    StrokeShape="RoundRectangle 15" BackgroundColor="#F3F4F6"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🍽️ Món ăn nên thử" FontSize="16"
                           FontAttributes="Bold" TextColor="#1F2937"/>
                    <Label x:Name="DetailMenu"
                           Text="• Ốc hương trứng muối&#10;• Càng ghẹ rang muối&#10;• Sò lông nướng mỡ hành"
                           FontSize="14" TextColor="#2C3E50"/>
                </VerticalStackLayout>
            </Border>

            <!-- 4 NÚT dạng Grid 2x2 -->
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*"
                  RowSpacing="10" ColumnSpacing="10"
                  Margin="20,20,20,30">
                <Button Grid.Row="0" Grid.Column="0"
                        x:Name="BtnFavorite"
                        Text="❤️ Yêu thích"
                        Clicked="OnFavoriteClicked"
                        BackgroundColor="#E74C3C" TextColor="White"
                        CornerRadius="20" HeightRequest="48"
                        FontAttributes="Bold" FontSize="13"/>
                <Button Grid.Row="0" Grid.Column="1"
                        Text="🔊 Nghe"
                        Clicked="OnSpeakClicked"
                        BackgroundColor="Orange" TextColor="White"
                        CornerRadius="20" HeightRequest="48"
                        FontAttributes="Bold" FontSize="13"/>
                <Button Grid.Row="1" Grid.Column="0"
                        Text="🗺️ Bản đồ"
                        Clicked="OnViewOnMapClicked"
                        BackgroundColor="#3B82F6" TextColor="White"
                        CornerRadius="20" HeightRequest="48"
                        FontAttributes="Bold" FontSize="13"/>
                <Button Grid.Row="1" Grid.Column="1"
                        Text="🧭 Dẫn đường"
                        Clicked="OnDirectClicked"
                        BackgroundColor="#1F2937" TextColor="White"
                        CornerRadius="20" HeightRequest="48"
                        FontAttributes="Bold" FontSize="13"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>