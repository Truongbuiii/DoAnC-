<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.Pages.PoiDetailPage"
             Title="Chi tiết địa điểm"
             BackgroundColor="#F9FAFB">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <Grid HeightRequest="300">
                <Image x:Name="MainImage" Aspect="AspectFill" Source="ocoanh.jpg"/>
                <BoxView Color="#66000000"/>
                <VerticalStackLayout VerticalOptions="End" Margin="20" Spacing="5">
                    <Label x:Name="DetailName" TextColor="White" FontSize="28" FontAttributes="Bold"/>
                    <Label x:Name="DetailCategory" TextColor="Orange" FontSize="16"/>
                </VerticalStackLayout>
                <ImageButton Source="back_icon.png" WidthRequest="30" HeightRequest="30" 
                             VerticalOptions="Start" HorizontalOptions="Start" 
                             Margin="20" Clicked="OnBackClicked"/>
            </Grid>

            <Border Margin="20,-20,20,0" Padding="20" BackgroundColor="White" StrokeShape="RoundRectangle 20" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,5" Radius="15" Opacity="0.1"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">
                    <Label Text="Giới thiệu &amp; Lịch sử" FontSize="18" FontAttributes="Bold" TextColor="#1F2937"/>
                    <Label x:Name="DetailDescription" FontSize="15" LineHeight="1.5" TextColor="#4B5563"/>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Padding="20" Spacing="20">
                <Border Padding="15" StrokeShape="RoundRectangle 15" BackgroundColor="#F3F4F6" StrokeThickness="0">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🍽️ Món ăn nên thử" FontSize="18" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Label x:Name="DetailMenu" Text="• Ốc hương trứng muối&#10;• Càng ghẹ rang muối&#10;• Sò lông nướng mỡ hành" FontSize="15" TextColor="#2C3E50"/>
                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Button x:Name="BtnFavorite"
            Text="🤍 Yêu thích"
            Clicked="OnFavoriteClicked"
            BackgroundColor="#E74C3C"
            TextColor="White"
            CornerRadius="25"
            WidthRequest="130" HeightRequest="45"
            FontAttributes="Bold"/>
                    <Button Text="🔊 Nghe"
            Clicked="OnSpeakClicked"
            BackgroundColor="Orange"
            TextColor="White"
            CornerRadius="25"
            WidthRequest="100" HeightRequest="45"
            FontAttributes="Bold"/>
                    <Button Text="🧭 Dẫn đường"
            Clicked="OnDirectClicked"
            BackgroundColor="#1F2937"
            TextColor="White"
            CornerRadius="25"
            WidthRequest="130" HeightRequest="45"
            FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>