<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.Pages.PoiDetailPage"
             Title=""
             BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <AbsoluteLayout HeightRequest="220">
                <BoxView Color="#1F2937"
                         AbsoluteLayout.LayoutFlags="All"
                         AbsoluteLayout.LayoutBounds="0,0,1,1"/>
                <Image x:Name="MainImage"
                       Source="{Binding FullImageUrl}"
                       Aspect="AspectFill"
                       AbsoluteLayout.LayoutFlags="All"
                       AbsoluteLayout.LayoutBounds="0,0,1,1"/>
                <BoxView AbsoluteLayout.LayoutFlags="All"
                         AbsoluteLayout.LayoutBounds="0,0,1,1">
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#33000000" Offset="0"/>
                            <GradientStop Color="#CC000000" Offset="1"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>
                <VerticalStackLayout Spacing="4"
                                     AbsoluteLayout.LayoutFlags="WidthProportional"
                                     AbsoluteLayout.LayoutBounds="16,150,0.92,AutoSize">
                    <Border BackgroundColor="#F97316"
                            StrokeShape="RoundRectangle 8"
                            Padding="8,3" HorizontalOptions="Start">
                        <Label x:Name="DetailCategory"
                               TextColor="White" FontSize="10" FontAttributes="Bold"/>
                    </Border>
                    <Label x:Name="DetailName"
                           TextColor="White" FontSize="20" FontAttributes="Bold"/>
                </VerticalStackLayout>
                <ImageButton Source="back_icon.png"
                             WidthRequest="40" HeightRequest="40"
                             Clicked="OnBackClicked"
                             BackgroundColor="#66000000" CornerRadius="20"
                             AbsoluteLayout.LayoutBounds="16,48,40,40"
                             AbsoluteLayout.LayoutFlags="None"/>
            </AbsoluteLayout>

            <!-- MÔ TẢ -->
            <Border Margin="16,-16,16,0" Padding="16"
                    BackgroundColor="White" StrokeShape="RoundRectangle 16" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="LblIntroTitle" FontSize="15"
                           FontAttributes="Bold" TextColor="#111827"/>
                    <BoxView HeightRequest="2" WidthRequest="36"
                             Color="#F97316" HorizontalOptions="Start" CornerRadius="2"/>
                    <Label x:Name="DetailDescription" FontSize="13"
                           LineHeight="1.6" TextColor="#4B5563"/>
                </VerticalStackLayout>
            </Border>

            <!-- MÓN ĂN -->
            <Border Margin="16,10,16,0" Padding="16"
                    BackgroundColor="White" StrokeShape="RoundRectangle 16" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="LblMenuTitle" FontSize="15"
                           FontAttributes="Bold" TextColor="#111827"/>
                    <BoxView HeightRequest="2" WidthRequest="36"
                             Color="#F97316" HorizontalOptions="Start" CornerRadius="2"/>
                    <Label x:Name="DetailMenu"
                           Text="• Ốc hương trứng muối&#10;• Càng ghẹ rang muối&#10;• Sò lông nướng mỡ hành"
                           FontSize="13" TextColor="#374151" LineHeight="1.5"/>
                </VerticalStackLayout>
            </Border>

            <!-- 4 NÚT -->
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*"
                  RowSpacing="8" ColumnSpacing="8" Margin="16,12,16,16">
                <Button Grid.Row="0" Grid.Column="0"
                        x:Name="BtnFavorite"
                        Clicked="OnFavoriteClicked"
                        BackgroundColor="#EF4444" TextColor="White"
                        CornerRadius="12" HeightRequest="46"
                        FontAttributes="Bold" FontSize="13"/>
                <Button Grid.Row="0" Grid.Column="1"
                        x:Name="BtnListen"
                        Clicked="OnSpeakClicked"
                        BackgroundColor="#F97316" TextColor="White"
                        CornerRadius="12" HeightRequest="46"
                        FontAttributes="Bold" FontSize="13"/>
                <Button Grid.Row="1" Grid.Column="0"
                        x:Name="BtnMap"
                        Clicked="OnViewOnMapClicked"
                        BackgroundColor="#3B82F6" TextColor="White"
                        CornerRadius="12" HeightRequest="46"
                        FontAttributes="Bold" FontSize="13"/>
                <Button Grid.Row="1" Grid.Column="1"
                        x:Name="BtnNavigate"
                        Clicked="OnDirectClicked"
                        BackgroundColor="#1F2937" TextColor="White"
                        CornerRadius="12" HeightRequest="46"
                        FontAttributes="Bold" FontSize="13"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>