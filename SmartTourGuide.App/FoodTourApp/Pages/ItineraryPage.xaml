<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTourApp.Pages.ItineraryPage"
             Title="Lộ trình"
             BackgroundColor="#F9FAFB">

    <Grid RowDefinitions="Auto, *">

        <!-- HEADER -->
        <Border Grid.Row="0" BackgroundColor="White" StrokeThickness="0" Padding="20,15">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="5">
                <Label Text="🗺️ LỘ TRÌNH TOUR" FontSize="20" FontAttributes="Bold" TextColor="#1F2937"/>
                <Label Text="Chọn tour và bắt đầu khám phá phố ẩm thực Vĩnh Khánh"
                       FontSize="12" TextColor="Gray"/>
            </VerticalStackLayout>
        </Border>

        <!-- DANH SÁCH TOUR -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15" Spacing="15">

                <!-- TOUR 1 -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,3" Radius="10" Opacity="0.1"/>
                    </Border.Shadow>
                    <VerticalStackLayout>
                        <!-- Ảnh header tour -->
                        <Grid HeightRequest="140">
                            <Image Source="ocoanh.jpg" Aspect="AspectFill"/>
                            <BoxView Color="#AA000000"/>
                            <VerticalStackLayout VerticalOptions="End" Padding="15,10">
                                <Label Text="🦪 Tour Ốc Huyền Thoại" TextColor="White"
                                       FontSize="18" FontAttributes="Bold"/>
                                <HorizontalStackLayout Spacing="15">
                                    <Label Text="⏱️ 90 phút" TextColor="#DDD" FontSize="12"/>
                                    <Label Text="📍 3 điểm" TextColor="#DDD" FontSize="12"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Danh sách điểm dừng -->
                        <VerticalStackLayout Padding="15" Spacing="10">
                            <Label Text="Các điểm dừng:" FontAttributes="Bold" TextColor="#1F2937"/>

                            <!-- Điểm 1 -->
                            <Grid ColumnDefinitions="30, *">
                                <Border Grid.Column="0" BackgroundColor="Orange"
                                        StrokeShape="RoundRectangle 15"
                                        WidthRequest="26" HeightRequest="26"
                                        HorizontalOptions="Center">
                                    <Label Text="1" TextColor="White" FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Margin="10,0">
                                    <Label Text="Cổng chào Phố ẩm thực" FontAttributes="Bold" FontSize="14"/>
                                    <Label Text="Điểm xuất phát · Ăn vặt" TextColor="Gray" FontSize="12"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F0F0F0" Margin="30,0,0,0"/>

                            <!-- Điểm 2 -->
                            <Grid ColumnDefinitions="30, *">
                                <Border Grid.Column="0" BackgroundColor="Orange"
                                        StrokeShape="RoundRectangle 15"
                                        WidthRequest="26" HeightRequest="26"
                                        HorizontalOptions="Center">
                                    <Label Text="2" TextColor="White" FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Margin="10,0">
                                    <Label Text="Ốc Oanh 534" FontAttributes="Bold" FontSize="14"/>
                                    <Label Text="~200m · Hải sản" TextColor="Gray" FontSize="12"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F0F0F0" Margin="30,0,0,0"/>

                            <!-- Điểm 3 -->
                            <Grid ColumnDefinitions="30, *">
                                <Border Grid.Column="0" BackgroundColor="Orange"
                                        StrokeShape="RoundRectangle 15"
                                        WidthRequest="26" HeightRequest="26"
                                        HorizontalOptions="Center">
                                    <Label Text="3" TextColor="White" FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Margin="10,0">
                                    <Label Text="Ốc Vũ 37" FontAttributes="Bold" FontSize="14"/>
                                    <Label Text="~100m · Hải sản" TextColor="Gray" FontSize="12"/>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Nút bắt đầu -->
                            <Button Text="▶️ Bắt đầu Tour này"
                                    BackgroundColor="Orange" TextColor="White"
                                    CornerRadius="12" HeightRequest="45"
                                    Margin="0,10,0,0"
                                    Clicked="OnStartTour1"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- TOUR 2 -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,3" Radius="10" Opacity="0.1"/>
                    </Border.Shadow>
                    <VerticalStackLayout>
                        <Grid HeightRequest="140">
                            <Image Source="phalau.jpg" Aspect="AspectFill"/>
                            <BoxView Color="#AA000000"/>
                            <VerticalStackLayout VerticalOptions="End" Padding="15,10">
                                <Label Text="🍢 Ăn Vặt Xế Chiều" TextColor="White"
                                       FontSize="18" FontAttributes="Bold"/>
                                <HorizontalStackLayout Spacing="15">
                                    <Label Text="⏱️ 60 phút" TextColor="#DDD" FontSize="12"/>
                                    <Label Text="📍 4 điểm" TextColor="#DDD" FontSize="12"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Padding="15" Spacing="10">
                            <Label Text="Các điểm dừng:" FontAttributes="Bold" TextColor="#1F2937"/>

                            <Grid ColumnDefinitions="30, *">
                                <Border Grid.Column="0" BackgroundColor="#6B7280"
                                        StrokeShape="RoundRectangle 15"
                                        WidthRequest="26" HeightRequest="26"
                                        HorizontalOptions="Center">
                                    <Label Text="1" TextColor="White" FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Margin="10,0">
                                    <Label Text="Sữa tươi chiên" FontAttributes="Bold" FontSize="14"/>
                                    <Label Text="Điểm xuất phát · Ăn vặt" TextColor="Gray" FontSize="12"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F0F0F0" Margin="30,0,0,0"/>

                            <Grid ColumnDefinitions="30, *">
                                <Border Grid.Column="0" BackgroundColor="#6B7280"
                                        StrokeShape="RoundRectangle 15"
                                        WidthRequest="26" HeightRequest="26"
                                        HorizontalOptions="Center">
                                    <Label Text="2" TextColor="White" FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Margin="10,0">
                                    <Label Text="Phá lấu Dì Nũi" FontAttributes="Bold" FontSize="14"/>
                                    <Label Text="~150m · Ăn vặt" TextColor="Gray" FontSize="12"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F0F0F0" Margin="30,0,0,0"/>

                            <Grid ColumnDefinitions="30, *">
                                <Border Grid.Column="0" BackgroundColor="#6B7280"
                                        StrokeShape="RoundRectangle 15"
                                        WidthRequest="26" HeightRequest="26"
                                        HorizontalOptions="Center">
                                    <Label Text="3" TextColor="White" FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Margin="10,0">
                                    <Label Text="Trà sữa túi lọc" FontAttributes="Bold" FontSize="14"/>
                                    <Label Text="~100m · Giải khát" TextColor="Gray" FontSize="12"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F0F0F0" Margin="30,0,0,0"/>

                            <Grid ColumnDefinitions="30, *">
                                <Border Grid.Column="0" BackgroundColor="#6B7280"
                                        StrokeShape="RoundRectangle 15"
                                        WidthRequest="26" HeightRequest="26"
                                        HorizontalOptions="Center">
                                    <Label Text="4" TextColor="White" FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Margin="10,0">
                                    <Label Text="Xôi gà hẻm 200" FontAttributes="Bold" FontSize="14"/>
                                    <Label Text="~200m · Ăn vặt" TextColor="Gray" FontSize="12"/>
                                </VerticalStackLayout>
                            </Grid>

                            <Button Text="▶️ Bắt đầu Tour này"
                                    BackgroundColor="#6B7280" TextColor="White"
                                    CornerRadius="12" HeightRequest="45"
                                    Margin="0,10,0,0"
                                    Clicked="OnStartTour2"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>