<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="FoodTourApp.Pages.QRPage"
             Title="Quét QR"
             BackgroundColor="Black">

    <Grid RowDefinitions="*, Auto">

        <zxing:CameraBarcodeReaderView
    x:Name="BarcodeReader"
    Grid.Row="0"
    BarcodesDetected="OnBarcodeDetected"
    HorizontalOptions="Fill"
    VerticalOptions="Fill">
            <zxing:CameraBarcodeReaderView.Options>
                <zxing:BarcodeReaderOptions
            Formats="QrCode"
            AutoRotate="True"
            Multiple="False"/>
            </zxing:CameraBarcodeReaderView.Options>
        </zxing:CameraBarcodeReaderView>
        VerticalOptions="Fill"/>

        <!-- Khung ngắm overlay -->
        <Grid Grid.Row="0" InputTransparent="True">
            <Border HorizontalOptions="Center" VerticalOptions="Center"
                    WidthRequest="250" HeightRequest="250"
                    Stroke="Orange" StrokeThickness="3"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="Transparent"/>
            <Label Text="Hướng camera vào mã QR của quán"
                   TextColor="White" FontSize="14"
                   HorizontalOptions="Center" VerticalOptions="End"
                   Margin="0,0,0,30"/>
        </Grid>

        <!-- Bottom controls -->
        <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="10"
                             BackgroundColor="#1F2937">
            <Label x:Name="StatusLabel"
                   Text="📷 Đang chờ quét mã QR..."
                   TextColor="White" FontSize="14"
                   HorizontalOptions="Center"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="🔦 Đèn flash"
                        Clicked="OnFlashToggle"
                        BackgroundColor="#374151" TextColor="White"
                        CornerRadius="10" HeightRequest="45"/>
                <Button Grid.Column="1" Text="📋 Nhập mã tay"
                        Clicked="OnManualEntry"
                        BackgroundColor="Orange" TextColor="White"
                        CornerRadius="10" HeightRequest="45"/>
            </Grid>
        </VerticalStackLayout>

    </Grid>
</ContentPage>