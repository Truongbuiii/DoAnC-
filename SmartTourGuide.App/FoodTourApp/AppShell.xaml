<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="FoodTourApp.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:FoodTourApp.Pages"
       xmlns:local="clr-namespace:FoodTourApp"
       Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Trang chủ">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage"/>
        </Tab>
        <Tab Title="Yêu thích">
            <ShellContent ContentTemplate="{DataTemplate pages:FavoritesPage}" Route="FavoritesPage"/>
        </Tab>
        <Tab Title="Bản đồ">
            <ShellContent ContentTemplate="{DataTemplate pages:MapPage}" Route="MapPage"/>
        </Tab>
        <Tab Title="Quét QR">
            <ShellContent ContentTemplate="{DataTemplate pages:QRPage}" Route="QRPage"/>
        </Tab>
        <Tab Title="Cài đặt">
            <ShellContent ContentTemplate="{DataTemplate pages:SettingsPage}" Route="SettingsPage"/>
        </Tab>
    </TabBar>

    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarBackgroundColor" Value="#FFFFFF"/>
            <Setter Property="Shell.TabBarForegroundColor" Value="#F97316"/>
            <Setter Property="Shell.TabBarTitleColor" Value="#F97316"/>
            <Setter Property="Shell.TabBarUnselectedColor" Value="#9CA3AF"/>
        </Style>
    </Shell.Resources>
</Shell>