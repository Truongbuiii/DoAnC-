<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodTourApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:FoodTourApp.Pages"
    xmlns:local="clr-namespace:FoodTourApp"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Trang chủ" Icon="home_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage"/>
        </Tab>
        <Tab Title="Bản đồ" Icon="map_icon.png">
            <ShellContent ContentTemplate="{DataTemplate pages:MapPage}" Route="MapPage"/>
        </Tab>
        <Tab Title="Yêu thích" Icon="heart_icon.png">
            <ShellContent ContentTemplate="{DataTemplate pages:FavoritesPage}" Route="FavoritesPage"/>
        </Tab>
        <Tab Title="Quét QR" Icon="qr_icon.png">
            <ShellContent ContentTemplate="{DataTemplate pages:QRPage}" Route="QRPage"/>
        </Tab>
        <Tab Title="Cài đặt" Icon="settings_icon.png">
            <ShellContent ContentTemplate="{DataTemplate pages:SettingsPage}" Route="SettingsPage"/>
        </Tab>
    </TabBar>

    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarBackgroundColor" Value="White" />
            <Setter Property="Shell.TabBarForegroundColor" Value="Orange" />
            <Setter Property="Shell.TabBarTitleColor" Value="Orange" />
            <Setter Property="Shell.TabBarUnselectedColor" Value="Gray" />
        </Style>
    </Shell.Resources>
</Shell>